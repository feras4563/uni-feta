<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40"><head><meta charset="UTF-8"><style>td,th{mso-number-format:\@;white-space:nowrap;border:1px solid #ccc;padding:4px 8px;font-family:Arial,sans-serif;font-size:12px;}th{background:#4472C4;color:#fff;font-weight:bold;}tr:nth-child(even) td{background:#f2f2f2;}</style></head><body><table dir="rtl"><tr><th>الرقم الجامعي</th><th>اسم الطالب</th><th>رمز المقرر</th><th>اسم المقرر</th><th>الدرجة</th><th>من</th></tr><tr><td>S000001</td><td>أحمد محمد علي</td><td>CS101</td><td>مقدمة في الحاسوب</td><td>30</td><td>40</td></tr><tr><td>S000002</td><td>فاطمة عبدالله</td><td>MATH201</td><td>رياضيات متقدمة</td><td>85</td><td>100</td></tr><tr><td>S000003</td><td>عمر حسين</td><td>ENG101</td><td>لغة إنجليزية</td><td>28</td><td>30</td></tr></table></body></html>