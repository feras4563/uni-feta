// File upload functions
export async function uploadSubjectPDF(file: File, subjectId: string): Promise<{ url: string; fileName: string; fileSize: number }> {
  const fileExt = file.name.split('.').pop();
  const fileName = `${subjectId}_${Date.now()}.${fileExt}`;
  const filePath = `subjects/pdfs/${fileName}`;

  const { data, error } = await supabase.storage
    .from('subject-files')
    .upload(filePath, file, {
      cacheControl: '3600',
      upsert: false
    });

  if (error) throw error;

  const { data: { publicUrl } } = supabase.storage
    .from('subject-files')
    .getPublicUrl(filePath);

  return {
    url: publicUrl,
    fileName: file.name,
    fileSize: file.size
  };
}

export async function deleteSubjectPDF(fileUrl: string): Promise<void> {
  // Extract file path from URL
  const urlParts = fileUrl.split('/');
  const fileName = urlParts[urlParts.length - 1];
  const filePath = `subjects/pdfs/${fileName}`;

  const { error } = await supabase.storage
    .from('subject-files')
    .remove([filePath]);

  if (error) throw error;
}

// Attendance API
export async function fetchAttendanceSessions(search?: string) {
  let query = supabase
    .from("attendance_sessions")
    .select(`
      id,
      class_id,
      subject,
      teacher_id,
      teacher_name,
      location,
      start_time,
      end_time,
      total_students,
      present_students,
      status,
      created_at
    `)
    .order("created_at", { ascending: false });

  if (search && search.trim()) {
    const s = search.trim();
    query = query.or(`subject.ilike.%${s}%,teacher_name.ilike.%${s}%,location.ilike.%${s}%`);
  }

  const { data, error } = await query;
  if (error) throw error;
  return data ?? [];
}

