// ==============================================
// AUTO GROUP CREATION FUNCTIONS
// ==============================================

export async function createAutoGroupsForDepartment(departmentId: string, semesterId: string, groupsPerSemester: number, maxStudentsPerGroup: number) {
  const groups = [];
  
  // Create groups for each semester number
  for (let semesterNumber = 1; semesterNumber <= groupsPerSemester; semesterNumber++) {
    for (let groupNumber = 1; groupNumber <= 3; groupNumber++) { // Create 3 groups per semester (A, B, C)
      const groupName = `Group ${String.fromCharCode(64 + groupNumber)}`; // A, B, C
      
      const groupData = {
        group_name: groupName,
        department_id: departmentId,
        semester_id: semesterId,
        semester_number: semesterNumber,
        max_students: maxStudentsPerGroup,
        description: `Auto-created group for semester ${semesterNumber}`
      };
      
      try {
        const { data, error } = await supabase
          .from("student_groups")
          .insert(groupData)
          .select()
          .single();
        
        if (error) throw error;
        groups.push(data);
      } catch (error) {
        console.error(`Error creating group ${groupName} for semester ${semesterNumber}:`, error);
      }
    }
  }
  
  return groups;
}

export async function assignStudentsToGroupsAutomatically(departmentId: string, semesterId: string) {
  // Get all students from the department
  const { data: students, error: studentsError } = await supabase
    .from("students")
    .select("*")
    .eq("department_id", departmentId)
    .eq("is_active", true);
  
  if (studentsError) throw studentsError;
  
  // Get available groups for this department and semester
  const { data: groups, error: groupsError } = await supabase
    .from("student_groups")
    .select("*")
    .eq("department_id", departmentId)
    .eq("semester_id", semesterId)
    .eq("is_active", true)
    .order("semester_number, group_name");
  
  if (groupsError) throw groupsError;
  
  if (!groups || groups.length === 0) {
    throw new Error("No groups found for this department and semester");
  }
  
  const registrations = [];
  let currentGroupIndex = 0;
  
  // Distribute students evenly across groups
  for (const student of students || []) {
    const currentGroup = groups[currentGroupIndex];
    
    // Check if group is full
    if (currentGroup.current_students >= currentGroup.max_students) {
      currentGroupIndex = (currentGroupIndex + 1) % groups.length;
      continue;
    }
    
    const registrationData = {
      student_id: student.id,
      semester_id: semesterId,
      study_year_id: null, // Will be set based on semester
      department_id: departmentId,
      group_id: currentGroup.id,
      semester_number: currentGroup.semester_number,
      status: 'active',
      tuition_paid: false
    };
    
    try {
      const { data, error } = await supabase
        .from("student_semester_registrations")
        .insert(registrationData)
        .select()
        .single();
      
      if (error) throw error;
      registrations.push(data);
      
      // Move to next group for next student
      currentGroupIndex = (currentGroupIndex + 1) % groups.length;
    } catch (error) {
      console.error(`Error registering student ${student.name}:`, error);
    }
  }
  
  return registrations;
}

// ==============================================
// REGISTRATION-BASED GROUP CREATION FUNCTIONS
// ==============================================

export async function getRegisteredStudentsBySemester(departmentId: string, semesterId: string) {
  try {
    console.log('🔍 Getting registered students for department:', departmentId, 'semester:', semesterId);
    
    // First try student_subject_enrollments (newer system)
    let { data: enrollments, error: enrollmentsError } = await supabase
      .from('student_subject_enrollments')
      .select(`
        id,
        student_id,
        semester_id,
        department_id,
        status,
        students(
          id,
          name,
          name_en,
          email,
          national_id_passport,
          phone,
          department_id
        )
      `)
      .eq('department_id', departmentId)
      .eq('semester_id', semesterId)
      .eq('status', 'enrolled');

    console.log('📊 Found enrollments:', enrollments?.length || 0);

    // If no enrollments found for exact department-semester match, try broader search
    if (!enrollments || enrollments.length === 0) {
      console.log('🔍 No exact matches, trying broader search...');
      
      // Get all enrollments for this semester
      const { data: semesterEnrollments, error: semesterError } = await supabase
        .from('student_subject_enrollments')
        .select(`
          id,
          student_id,
          semester_id,
          department_id,
          status,
          students(
            id,
            name,
            name_en,
            email,
            national_id_passport,
            phone,
            department_id
          )
        `)
        .eq('semester_id', semesterId)
        .eq('status', 'enrolled');

      if (semesterError) {
        console.error('❌ Error fetching semester enrollments:', semesterError);
        throw semesterError;
      }

      console.log('📊 Found semester enrollments:', semesterEnrollments?.length || 0);

      // Filter students who belong to the selected department
      const departmentStudents = semesterEnrollments?.filter(enrollment => 
        enrollment.students?.department_id === departmentId
      ) || [];

      console.log('📊 Students in department from semester enrollments:', departmentStudents.length);

      if (departmentStudents.length > 0) {
        enrollments = departmentStudents;
      } else {
        // Fallback: try student_semester_registrations (older system)
        console.log('🔍 Trying semester registrations as fallback...');
        
        const { data: registrations, error: registrationsError } = await supabase
          .from('student_semester_registrations')
          .select(`
            id,
            student_id,
            semester_id,
            department_id,
            semester_number,
            status,
            students(
              id,
              name,
              name_en,
              email,
              national_id_passport,
              phone,
              department_id
            )
          `)
          .eq('department_id', departmentId)
          .eq('semester_id', semesterId)
          .eq('status', 'active');

        if (registrationsError) {
          console.error('❌ Error fetching registrations:', registrationsError);
          throw registrationsError;
        }

        console.log('📊 Found registrations:', registrations?.length || 0);
        enrollments = registrations;
      }
    }

    // Get unique students (in case they have multiple registrations/enrollments)
    const uniqueStudents = new Map();
    enrollments?.forEach((record: any) => {
      if (record.students && !uniqueStudents.has(record.students.id)) {
        uniqueStudents.set(record.students.id, {
          ...record.students,
          registration_id: record.id,
          semester_number: record.semester_number || 1 // Default to 1 if not specified
        });
      }
    });

    const studentsArray = Array.from(uniqueStudents.values());
    console.log('👥 Unique registered students:', studentsArray.length);

    return studentsArray;
  } catch (error) {
    console.error('❌ Error in getRegisteredStudentsBySemester:', error);
    throw error;
  }
}

export async function createGroupsForRegisteredStudents(
  departmentId: string, 
  semesterId: string, 
  maxStudentsPerGroup: number = 30
) {
  try {
    console.log('🚀 Creating groups for registered students...');
    
    // First, get registered students
    const registeredStudents = await getRegisteredStudentsBySemester(departmentId, semesterId);
    
    if (registeredStudents.length === 0) {
      throw new Error('لا يوجد طلاب مسجلين في هذا القسم والفصل الدراسي');
    }

    console.log('👥 Registered students found:', registeredStudents.length);

    // Group students by semester number
    const studentsBySemester = new Map();
    registeredStudents.forEach(student => {
      const semesterNum = student.semester_number || 1;
      if (!studentsBySemester.has(semesterNum)) {
        studentsBySemester.set(semesterNum, []);
      }
      studentsBySemester.get(semesterNum).push(student);
    });

    console.log('📚 Students grouped by semester:', Object.fromEntries(studentsBySemester));

    const createdGroups = [];
    const studentAssignments = [];

    // Create groups for each semester number
    for (const [semesterNumber, students] of studentsBySemester) {
      console.log(`📖 Creating groups for semester ${semesterNumber} with ${students.length} students`);
      
      // Calculate number of groups needed
      const numberOfGroups = Math.ceil(students.length / maxStudentsPerGroup);
      console.log(`📊 Need ${numberOfGroups} groups for ${students.length} students`);

      // Create groups for this semester
      for (let groupIndex = 0; groupIndex < numberOfGroups; groupIndex++) {
        const groupLetter = String.fromCharCode(65 + groupIndex); // A, B, C, etc.
        const groupName = `Group ${groupLetter}`;
        
        const groupData = {
          group_name: groupName,
          department_id: departmentId,
          semester_id: semesterId,
          semester_number: semesterNumber,
          max_students: maxStudentsPerGroup,
          current_students: 0,
          description: `Auto-created group for registered students - Semester ${semesterNumber}`
        };

        try {
          const { data: newGroup, error: groupError } = await supabase
            .from("student_groups")
            .insert(groupData)
            .select()
            .single();

          if (groupError) throw groupError;
          
          createdGroups.push(newGroup);
          console.log(`✅ Created group: ${groupName} for semester ${semesterNumber}`);

          // Assign students to this group
          const startIndex = groupIndex * maxStudentsPerGroup;
          const endIndex = Math.min(startIndex + maxStudentsPerGroup, students.length);
          const studentsForThisGroup = students.slice(startIndex, endIndex);

          console.log(`👥 Assigning ${studentsForThisGroup.length} students to group ${groupName}`);

          for (const student of studentsForThisGroup) {
            try {
              // Check if student already has a semester registration
              const { data: existingRegistration, error: checkError } = await supabase
                .from("student_semester_registrations")
                .select("*")
                .eq("student_id", student.id)
                .eq("semester_id", semesterId)
                .eq("status", "active")
                .single();

              if (checkError && checkError.code !== 'PGRST116') { // PGRST116 = no rows returned
                throw checkError;
              }

              let result;

              if (existingRegistration) {
                // Student already has a semester registration, update it
                console.log(`📝 Updating existing registration for student ${student.name}`);
                const { data: updatedRegistration, error: updateError } = await supabase
                  .from("student_semester_registrations")
                  .update({
                    group_id: newGroup.id,
                    department_id: departmentId,
                    semester_number: semesterNumber
                  })
                  .eq('id', existingRegistration.id)
                  .select()
                  .single();

                if (updateError) throw updateError;
                result = updatedRegistration;
              } else {
                // Create new semester registration for the student
                console.log(`🆕 Creating new registration for student ${student.name}`);
                const registrationData = {
                  student_id: student.id,
                  semester_id: semesterId,
                  department_id: departmentId,
                  group_id: newGroup.id,
                  semester_number: semesterNumber,
                  status: 'active',
                  tuition_paid: false,
                  registration_date: new Date().toISOString()
                };

                const { data: newRegistration, error: createError } = await supabase
                  .from("student_semester_registrations")
                  .insert(registrationData)
                  .select()
                  .single();

                if (createError) throw createError;
                result = newRegistration;
              }
              
              studentAssignments.push({
                student_id: student.id,
                group_id: newGroup.id,
                group_name: groupName,
                semester_number: semesterNumber
              });

              console.log(`✅ Assigned student ${student.name} to group ${groupName}`);
            } catch (error) {
              console.error(`❌ Error assigning student ${student.name} to group:`, error);
            }
          }

          // Update group current_students count
          await updateGroupStudentCount(newGroup.id);

        } catch (error) {
          console.error(`❌ Error creating group ${groupName}:`, error);
        }
      }
    }

    console.log('🎉 Group creation completed!');
    console.log('📊 Summary:', {
      totalGroups: createdGroups.length,
      totalStudents: studentAssignments.length,
      groupsBySemester: Object.fromEntries(studentsBySemester)
    });

    return {
      groups: createdGroups,
      assignments: studentAssignments,
      summary: {
        totalGroups: createdGroups.length,
        totalStudents: studentAssignments.length,
        studentsBySemester: Object.fromEntries(studentsBySemester)
      }
    };

  } catch (error) {
    console.error('❌ Error in createGroupsForRegisteredStudents:', error);
    throw error;
  }
}

export async function getStudentsWithoutGroups(departmentId?: string) {
  let query = supabase
    .from("students")
    .select(`
      *,
      departments(id, name, name_en)
    `)
    .eq("is_active", true);
  
  if (departmentId) {
    query = query.eq("department_id", departmentId);
  }
  
  const { data: allStudents, error: studentsError } = await query;
  if (studentsError) throw studentsError;
  
  // Get students who are already registered
  const { data: registeredStudents, error: regError } = await supabase
    .from("student_semester_registrations")
    .select("student_id")
    .eq("status", "active");
  
  if (regError) throw regError;
  
  const registeredStudentIds = new Set(registeredStudents?.map(r => r.student_id) || []);
  
  // Filter out students who are already registered
  const unregisteredStudents = allStudents?.filter(student => 
    !registeredStudentIds.has(student.id)
  ) || [];
  
  return unregisteredStudents;
}

