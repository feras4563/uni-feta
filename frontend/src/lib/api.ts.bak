export async function fetchDepartmentSemesterSubjects(departmentId: string, semesterNumber?: number) {
  let query = supabase
    .from("department_semester_subjects")
    .select(`
      *,
      subjects(id, name, name_en, code, credits)
    `)
    .eq("department_id", departmentId);

  if (semesterNumber) {
    query = query.eq("semester_number", semesterNumber);
  }

  const { data, error } = await query;
  if (error) throw error;
  return data ?? [];
}

export async function createDepartmentSemesterSubjects(departmentId: string, semesterNumber: number, subjectIds: string[]) {
  const assignments = subjectIds.map(subjectId => ({
    department_id: departmentId,
    semester_number: semesterNumber,
    semester_id: null, // Set to null since we're using semester_number
    subject_id: subjectId,
    is_active: true
  }));

  const { data, error } = await supabase
    .from("department_semester_subjects")
    .insert(assignments)
    .select();

  if (error) throw error;
  return data;
}

export async function updateDepartmentSemesterSubjects(departmentId: string, semesterNumber: number, subjectIds: string[]) {
  // First delete existing assignments for this department-semester combination
  await supabase
    .from("department_semester_subjects")
    .delete()
    .eq("department_id", departmentId)
    .eq("semester_number", semesterNumber);

  // Then create new assignments
  if (subjectIds.length > 0) {
    return await createDepartmentSemesterSubjects(departmentId, semesterNumber, subjectIds);
  }

  return [];
}

export async function deleteDepartmentSemesterSubject(departmentId: string, semesterNumber: number, subjectId: string) {
  const { error } = await supabase
    .from("department_semester_subjects")
    .delete()
    .eq("department_id", departmentId)
    .eq("semester_number", semesterNumber)
    .eq("subject_id", subjectId);

  if (error) throw error;
}

