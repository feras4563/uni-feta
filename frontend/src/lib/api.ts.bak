export async function fetchDepartmentCurriculumBySemesterNumber(departmentId: string, semesterNumber: number) {
  console.log("🔍 fetchDepartmentCurriculumBySemesterNumber called with:", { departmentId, semesterNumber });
  
  // Use the same approach as DepartmentDetail page - query department_semester_subjects table
  const { data: semesterSubjectsData, error: semesterSubjectsError } = await supabase
    .from("department_semester_subjects")
    .select(`
      id,
      department_id,
      semester_id,
      subject_id,
      semester_number,
      is_active,
      subjects!inner(
        id, 
        code, 
        name, 
        name_en, 
        credits, 
        cost_per_credit, 
        total_cost, 
        is_required, 
        semester_number
      ),
      semesters(id, name, name_en),
      departments(id, name, name_en)
    `)
    .eq("department_id", departmentId)
    .eq("semester_number", semesterNumber)
    .eq("is_active", true)
    .order("name", { referencedTable: "subjects" });

  console.log("📊 department_semester_subjects query result:", { semesterSubjectsData, semesterSubjectsError });

  if (semesterSubjectsError) {
    console.error("❌ Error in department_semester_subjects query:", semesterSubjectsError);
    throw semesterSubjectsError;
  }

  // Transform the data to match the expected format
  const transformedData = semesterSubjectsData?.map(item => ({
    id: item.id,
    department_id: item.department_id,
    semester_id: item.semester_id,
    subject_id: item.subject_id,
    semester_number: item.semester_number,
    is_required: item.subjects?.is_required ?? true,
    is_active: item.is_active,
    subjects: item.subjects,
    semesters: item.semesters,
    departments: item.departments
  })) ?? [];

  console.log("✅ Returning transformed data:", transformedData.length, "items");
  return transformedData;
}

