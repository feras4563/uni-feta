// ============================================================================
// TEACHER-SUBJECT LINKING API
// ============================================================================

export async function fetchTeacherSubjects(teacherId: string) {
  const { data, error } = await supabase
    .from("teacher_subjects")
    .select(`
      *,
      subject:subjects(id, name, code, credits),
      department:departments(id, name, name_en),
      study_years(id, name, name_en),
      semesters(id, name, name_en, code)
    `)
    .eq("teacher_id", teacherId)
    .eq("is_active", true)
    .order("created_at", { ascending: false });

  if (error) throw error;
  
  // Sort in memory by study year and semester
  const sortedData = (data ?? []).sort((a: any, b: any) => {
    // Sort by study year descending
    const yearCompare = (b.study_years?.name || '').localeCompare(a.study_years?.name || '');
    if (yearCompare !== 0) return yearCompare;
    
    // Then sort by semester name ascending
    return (a.semesters?.name || '').localeCompare(b.semesters?.name || '');
  });
  
  return sortedData;
}

// Fetch all teacher-subject assignments (for the assignment management page)
export async function fetchAllTeacherSubjectAssignments() {
  // First, get the basic assignments data
  const { data: assignments, error: assignmentsError } = await supabase
    .from("teacher_subjects")
    .select("*")
    .order("created_at", { ascending: false });

  if (assignmentsError) throw assignmentsError;

  if (!assignments || assignments.length === 0) {
    return [];
  }

  // Get all unique IDs for related data
  const subjectIds = [...new Set(assignments.map(item => item.subject_id).filter(Boolean))];
  const departmentIds = [...new Set(assignments.map(item => item.department_id).filter(Boolean))];
  const studyYearIds = [...new Set(assignments.map(item => item.study_year_id).filter(Boolean))];
  const semesterIds = [...new Set(assignments.map(item => item.semester_id).filter(Boolean))];
  const teacherIds = [...new Set(assignments.map(item => item.teacher_id).filter(Boolean))];

  // Fetch all related data in parallel
  const [subjectsResult, departmentsResult, studyYearsResult, semestersResult, teachersResult] = await Promise.all([
    subjectIds.length > 0 ? supabase.from("subjects").select("id, name, code, credits").in("id", subjectIds) : { data: [], error: null },
    departmentIds.length > 0 ? supabase.from("departments").select("id, name, name_en").in("id", departmentIds) : { data: [], error: null },
    studyYearIds.length > 0 ? supabase.from("study_years").select("id, name, name_en").in("id", studyYearIds) : { data: [], error: null },
    semesterIds.length > 0 ? supabase.from("semesters").select("id, name, name_en, code").in("id", semesterIds) : { data: [], error: null },
    teacherIds.length > 0 ? supabase.from("teachers").select("id, name, email").in("id", teacherIds) : { data: [], error: null }
  ]);

  // Check for errors
  if (subjectsResult.error) throw subjectsResult.error;
  if (departmentsResult.error) throw departmentsResult.error;
  if (studyYearsResult.error) throw studyYearsResult.error;
  if (semestersResult.error) throw semestersResult.error;
  if (teachersResult.error) throw teachersResult.error;

  // Create lookup objects
  const subjectsLookup = subjectsResult.data?.reduce((acc, item) => {
    acc[item.id] = item;
    return acc;
  }, {} as Record<string, any>) || {};

  const departmentsLookup = departmentsResult.data?.reduce((acc, item) => {
    acc[item.id] = item;
    return acc;
  }, {} as Record<string, any>) || {};

  const studyYearsLookup = studyYearsResult.data?.reduce((acc, item) => {
    acc[item.id] = item;
    return acc;
  }, {} as Record<string, any>) || {};

  const semestersLookup = semestersResult.data?.reduce((acc, item) => {
    acc[item.id] = item;
    return acc;
  }, {} as Record<string, any>) || {};

  const teachersLookup = teachersResult.data?.reduce((acc, item) => {
    acc[item.id] = item;
    return acc;
  }, {} as Record<string, any>) || {};

  // Combine all data
  const assignmentsWithRelations = assignments.map(assignment => ({
    ...assignment,
    subjects: subjectsLookup[assignment.subject_id] || null,
    departments: departmentsLookup[assignment.department_id] || null,
    study_years: studyYearsLookup[assignment.study_year_id] || null,
    semesters: semestersLookup[assignment.semester_id] || null,
    teachers: teachersLookup[assignment.teacher_id] || null
  }));

  return assignmentsWithRelations;
}

export async function fetchSubjectTeachers(subjectId: string) {
  const { data, error } = await supabase
    .from("teacher_subjects")
    .select(`
      *,
      teacher:teachers(id, name, name_en, email),
      department:departments(id, name, name_en)
    `)
    .eq("subject_id", subjectId)
    .eq("is_active", true)
    .order("is_primary_teacher", { ascending: false })
    .order("academic_year", { ascending: false });

  if (error) throw error;
  return data ?? [];
}

export async function createTeacherSubjectAssignment(assignmentData: {
  teacher_id: string;
  subject_id: string;
  department_id: string;
  study_year_id: string;
  semester_id: string;
  is_primary_teacher?: boolean;
  can_edit_grades?: boolean;
  can_take_attendance?: boolean;
  notes?: string;
}) {
  try {
    // Get the study year and semester names for backward compatibility
    const { data: studyYear } = await supabase
      .from("study_years")
      .select("name")
      .eq("id", assignmentData.study_year_id)
      .single();

    const { data: semester } = await supabase
      .from("semesters")
      .select("name")
      .eq("id", assignmentData.semester_id)
      .single();

    // Map semester name to constraint-compatible value
    const mapSemesterName = (semesterName: string) => {
      const name = semesterName?.toLowerCase() || '';
      if (name.includes('خريف') || name.includes('fall')) return 'fall';
      if (name.includes('ربيع') || name.includes('spring')) return 'spring';
      if (name.includes('صيف') || name.includes('summer')) return 'summer';
      return 'fall'; // default fallback
    };

    const academicYearName = studyYear?.name || "2024-2025";
    const semesterName = mapSemesterName(semester?.name || "fall");

    // Check if assignment already exists using foreign keys
    const { data: existingAssignment } = await supabase
      .from("teacher_subjects")
      .select("id, is_active")
      .eq("teacher_id", assignmentData.teacher_id)
      .eq("subject_id", assignmentData.subject_id)
      .eq("department_id", assignmentData.department_id)
      .eq("study_year_id", assignmentData.study_year_id)
      .eq("semester_id", assignmentData.semester_id)
      .eq("is_active", true)
      .single();

    if (existingAssignment) {
      throw new Error("هذا المدرس مكلف بالفعل بهذه المادة في نفس القسم والفصل الدراسي والسنة الأكاديمية");
    }

    // Try to insert with new structure first
    const insertData = {
      ...assignmentData,
      academic_year: academicYearName,
      semester: semesterName
    };

    const { data, error } = await supabase
      .from("teacher_subjects")
      .insert([insertData])
      .select(`
        *,
        study_years(id, name, name_en),
        semesters(id, name, name_en, code)
      `)
      .single();

    if (error) throw error;
    return data;
  } catch (error: any) {
    // If the new columns don't exist, fall back to old structure
    if (error.message?.includes('column "study_year_id" does not exist') || 
        error.message?.includes('column "semester_id" does not exist')) {
      
      // Get the study year and semester names
      const { data: studyYear } = await supabase
        .from("study_years")
        .select("name")
        .eq("id", assignmentData.study_year_id)
        .single();

      const { data: semester } = await supabase
        .from("semesters")
        .select("name")
        .eq("id", assignmentData.semester_id)
        .single();

      // Map semester name to constraint-compatible value
      const mapSemesterName = (semesterName: string) => {
        const name = semesterName?.toLowerCase() || '';
        if (name.includes('خريف') || name.includes('fall')) return 'fall';
        if (name.includes('ربيع') || name.includes('spring')) return 'spring';
        if (name.includes('صيف') || name.includes('summer')) return 'summer';
        return 'fall'; // default fallback
      };

      const academicYearName = studyYear?.name || "2024-2025";
      const semesterName = mapSemesterName(semester?.name || "fall");

      // Check if assignment already exists (old structure)
      const { data: existingAssignment } = await supabase
        .from("teacher_subjects")
        .select("id, is_active")
        .eq("teacher_id", assignmentData.teacher_id)
        .eq("subject_id", assignmentData.subject_id)
        .eq("department_id", assignmentData.department_id)
        .eq("academic_year", academicYearName)
        .eq("semester", semesterName)
        .single();

      if (existingAssignment) {
        if (existingAssignment.is_active) {
          throw new Error("هذا المدرس مكلف بالفعل بهذه المادة في نفس الفصل الدراسي");
        } else {
          // Reactivate the existing assignment
          const { data, error } = await supabase
            .from("teacher_subjects")
            .update({
              is_active: true,
              is_primary_teacher: assignmentData.is_primary_teacher,
              can_edit_grades: assignmentData.can_edit_grades,
              can_take_attendance: assignmentData.can_take_attendance,
              notes: assignmentData.notes
            })
            .eq("id", existingAssignment.id)
            .select("*")
            .single();

          if (error) throw error;
          return data;
        }
      }

      // Use old structure
      const fallbackData = {
        teacher_id: assignmentData.teacher_id,
        subject_id: assignmentData.subject_id,
        department_id: assignmentData.department_id,
        academic_year: academicYearName,
        semester: semesterName,
        is_primary_teacher: assignmentData.is_primary_teacher,
        can_edit_grades: assignmentData.can_edit_grades,
        can_take_attendance: assignmentData.can_take_attendance,
        notes: assignmentData.notes
      };

      const { data, error: fallbackError } = await supabase
        .from("teacher_subjects")
        .insert([fallbackData])
        .select("*")
        .single();

      if (fallbackError) throw fallbackError;
      return data;
    }
    throw error;
  }
}

export async function updateTeacherSubjectAssignment(id: string, assignmentData: any) {
  // If updating study_year_id or semester_id, also update the old columns for backward compatibility
  let updateData = { ...assignmentData };
  
  if (assignmentData.study_year_id) {
    const { data: studyYear } = await supabase
      .from("study_years")
      .select("name")
      .eq("id", assignmentData.study_year_id)
      .single();
    updateData.academic_year = studyYear?.name || null;
  }
  
  if (assignmentData.semester_id) {
    const { data: semester } = await supabase
      .from("semesters")
      .select("name")
      .eq("id", assignmentData.semester_id)
      .single();
    updateData.semester = semester?.name || null;
  }

  const { data, error } = await supabase
    .from("teacher_subjects")
    .update(updateData)
    .eq("id", id)
    .select(`
      *,
      study_years(id, name, name_en),
      semesters(id, name, name_en, code)
    `)
    .single();

  if (error) throw error;
  return data;
}

