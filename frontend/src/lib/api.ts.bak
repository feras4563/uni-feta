// MIGRATED TO JWT AUTH - This file now uses jwt-api.ts
// Keeping this file for backward compatibility during migration
export * from './jwt-api';

export async function fetchStudents(search?: string) {
  let query = supabase
    .from("students")
    .select(`
      id,
      name,
      name_en,
      department_id,
      year,
      status,
      national_id_passport,
      email,
      phone,
      gender,
      nationality,
      birth_date,
      enrollment_date,
      address,
      sponsor_name,
      sponsor_contact,
      academic_history,
      academic_score,
      transcript_file,
      qr_code,
      created_at,
      updated_at,
      departments(id, name)
    `)
    .order("created_at", { ascending: false });

  if (search && search.trim()) {
    const s = search.trim();
    query = query.or(`name.ilike.%${s}%,name_en.ilike.%${s}%,national_id_passport.ilike.%${s}%,id.eq.${s}`);
  }

  const { data, error } = await query;
  if (error) throw error;
  return data ?? [];
}

export async function fetchTeachers(search?: string, activeOnly: boolean = true) {
  let query = supabase
    .from("teachers")
    .select("id, name, name_en, email, phone, qualification, education_level, specialization, years_experience, availability, specializations, teaching_hours, hourly_rate, basic_salary, is_active, created_at, updated_at")
    .order("name");

  // Only show active teachers from teachers master
  if (activeOnly) {
    query = query.eq("is_active", true);
  }

  if (search && search.trim()) {
    const s = search.trim();
    query = query.or(`name.ilike.%${s}%,name_en.ilike.%${s}%,phone.ilike.%${s}%,qualification.ilike.%${s}%,id.eq.${s}`);
  }

  const { data, error } = await query;
  if (error) throw error;
  return data ?? [];
}

export async function fetchDepartments() {
  const { data, error } = await supabase
    .from("departments")
    .select(`
      id,
      name,
      name_en,
      head,
      head_teacher_id,
      is_locked,
      created_at,
      updated_at
    `)
    .order("name");
  if (error) throw error;
  
  // Fetch head teachers separately to avoid join issues
  const departmentsWithTeachers = await Promise.all(
    (data || []).map(async (dept) => {
      if (dept.head_teacher_id) {
        try {
          const { data: teacher } = await supabase
            .from("teachers")
            .select("id, name, name_en")
            .eq("id", dept.head_teacher_id)
            .single();
          return { ...dept, head_teacher: teacher };
        } catch (err) {
          console.warn(`Could not fetch teacher ${dept.head_teacher_id}:`, err);
          return { ...dept, head_teacher: null };
        }
      }
      return { ...dept, head_teacher: null };
    })
  );
  
  return departmentsWithTeachers;
}

export async function fetchDepartmentDetails(departmentId: string) {
  // Fetch department basic info
  const { data: department, error: deptError } = await supabase
    .from("departments")
    .select(`
      id,
      name,
      name_en,
      head,
      head_teacher_id,
      is_locked,
      created_at,
      updated_at
    `)
    .eq("id", departmentId)
    .single();

  if (deptError) throw deptError;

  // Fetch head teacher info if exists
  let headTeacher = null;
  if (department.head_teacher_id) {
    const { data: teacher } = await supabase
      .from("teachers")
      .select("id, name, name_en")
      .eq("id", department.head_teacher_id)
      .single();
    headTeacher = teacher;
  }

  // Fetch subjects for this department using department_semester_subjects table
  const { data: subjects, error: subjectsError } = await supabase
    .from("department_semester_subjects")
    .select(`
      semester_number,
      semester_id,
      subjects!inner(
        id,
        code,
        name,
        name_en,
        credits,
        semester,
        max_students,
        created_at
      )
    `)
    .eq("department_id", departmentId);

  if (subjectsError) throw subjectsError;

  // Fetch semester information using semester_number from department_semester_subjects
  const semesterData = subjects?.reduce((acc: any, item: any) => {
    const semesterNumber = item.semester_number || 1;
    const semesterKey = `الفصل ${semesterNumber}`;
    
    if (!acc[semesterKey]) {
      acc[semesterKey] = {
        name: semesterKey,
        semesterNumber: semesterNumber,
        subjects: [],
        totalCredits: 0,
        totalSubjects: 0
      };
    }
    acc[semesterKey].subjects.push(item.subjects);
    acc[semesterKey].totalCredits += item.subjects.credits || 0;
    acc[semesterKey].totalSubjects += 1;
    return acc;
  }, {}) || {};

  // Fetch students count
  const { count: studentsCount } = await supabase
    .from("students")
    .select("*", { count: "exact", head: true })
    .eq("department_id", departmentId);

  // Fetch active students count
  const { count: activeStudentsCount } = await supabase
    .from("students")
    .select("*", { count: "exact", head: true })
    .eq("department_id", departmentId)
    .eq("status", "active");

  return {
    department: { ...department, head_teacher: headTeacher },
    semesters: Object.values(semesterData),
    totalSubjects: subjects?.length || 0,
    totalStudents: studentsCount || 0,
    activeStudents: activeStudentsCount || 0,
    totalSemesters: Object.keys(semesterData).length
  };
}

export async function fetchDepartmentWithStats(departmentId: string) {
  const [deptRes, studentsRes, departmentSemesterSubjectsRes, feesRes, materialsRes] = await Promise.all([
    supabase
      .from("departments")
      .select("*")
      .eq("id", departmentId)
      .single(),
    supabase
      .from("students")
      .select("id, name, status")
      .eq("department_id", departmentId),
    supabase
      .from("department_semester_subjects")
      .select(`
        id,
        semester_number,
        subject_id,
        is_active,
        subjects!inner(id, name, code, credits)
      `)
      .eq("department_id", departmentId)
      .eq("is_active", true),
    supabase
      .from("fees")
      .select(`
        id, 
        amount, 
        status,
        student:students!inner(id, department_id)
      `)
      .eq("student.department_id", departmentId),
    supabase
      .from("study_materials")
      .select("id, title, material_type, author, semester, is_required")
      .eq("department_id", departmentId)
      .eq("is_active", true)
      .limit(0) // Return empty result if table doesn't exist
  ]);

  if (deptRes.error) throw deptRes.error;

  const students = studentsRes.data || [];
  const departmentSemesterSubjects = departmentSemesterSubjectsRes.data || [];
  const fees = feesRes.data || [];
  const materials = materialsRes.error ? [] : (materialsRes.data || []); // Handle missing table gracefully

  // Group subjects by semester number
  const subjectsBySemester = departmentSemesterSubjects.reduce((acc: any, item) => {
    const semesterNumber = item.semester_number;
    const semesterName = `الفصل ${semesterNumber}`;
    if (!acc[semesterName]) {
      acc[semesterName] = {
        semester_number: semesterNumber,
        semester_name: semesterName,
        subjects: []
      };
    }
    acc[semesterName].subjects.push(item.subjects);
    return acc;
  }, {});

  // Extract all subjects for backward compatibility
  const subjects = departmentSemesterSubjects.map(item => item.subjects);

  // Group materials by semester
  const materialsBySemester = materials.reduce((acc: any, material) => {
    const semester = material.semester || 'غير محدد';
    if (!acc[semester]) {
      acc[semester] = [];
    }
    acc[semester].push(material);
    return acc;
  }, {});

  // Get unique semesters
  const semesters = Object.keys(subjectsBySemester).sort((a, b) => {
    // Sort semesters naturally (1, 2, 3, 4, etc.)
    const aNum = parseInt(a) || 999;
    const bNum = parseInt(b) || 999;
    return aNum - bNum;
  });

  return {
    department: deptRes.data,
    students: {
      total: students.length,
      active: students.filter(s => s.status === 'active').length,
      data: students
    },
    subjects: {
      total: subjects.length,
      data: subjects,
      bySemester: subjectsBySemester,
      semesters: semesters
    },
    materials: {
      total: materials.length,
      data: materials,
      bySemester: materialsBySemester,
      required: materials.filter(m => m.is_required).length,
      optional: materials.filter(m => !m.is_required).length
    },
    fees: {
      total: fees.length,
      totalAmount: fees.reduce((sum, f) => sum + (f.amount || 0), 0),
      paid: fees.filter(f => f.status === 'paid').length,
      unpaid: fees.filter(f => f.status === 'unpaid').length
    }
  };
}

export async function fetchFees() {
  const { data, error } = await supabase
    .from("fees")
    .select(`
      id,
      amount,
      status,
      due_date,
      paid_date,
      paid_amount,
      receipt_no,
      academic_year,
      type,
      fee_type_id,
      payment_plan_id,
      payment_notes,
      created_at,
      updated_at,
      student:students(id,name,department_id,year),
      fee_type:fee_types(id,name,code),
      payment_plan:payment_plans(id,name,installments_count)
    `)
    .order("created_at", { ascending: false });
  if (error) throw error;
  return data ?? [];
}

export async function createPayment(feeId: number, amount: number, method: string, referenceNumber?: string, notes?: string) {
  const receiptNumber = `RCT-${Date.now().toString(36)}-${Math.random().toString(36).substr(2, 5)}`.toUpperCase();
  
  const { error } = await supabase.from("fee_payments").insert({
    fee_id: feeId,
    amount,
    payment_method: method,
    payment_date: new Date().toISOString(),
    receipt_number: receiptNumber,
    reference_number: referenceNumber || null,
    notes: notes || null
  });
  if (error) throw error;
  return receiptNumber;
}

