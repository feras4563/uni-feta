// New functions for handling subject-department relationships
export async function createSubjectWithDepartments(subjectData: any, departmentIds: string[], primaryDepartmentId?: string) {
  // First create the subject
  const { data: subject, error: subjectError } = await supabase
    .from("subjects")
    .insert([subjectData])
    .select()
    .single();

  if (subjectError) throw subjectError;

  // Then create the department relationships
  if (departmentIds.length > 0) {
    const relationships = departmentIds.map(deptId => ({
      subject_id: subject.id,
      department_id: deptId,
      is_primary_department: deptId === primaryDepartmentId || (primaryDepartmentId ? false : deptId === departmentIds[0])
    }));

    const { error: relError } = await supabase
      .from("subject_departments")
      .insert(relationships);

    if (relError) throw relError;
  }

  return subject;
}

export async function updateSubjectDepartments(subjectId: string, departmentIds: string[], primaryDepartmentId?: string) {
  // First, remove existing relationships
  const { error: deleteError } = await supabase
    .from("subject_departments")
    .delete()
    .eq("subject_id", subjectId);

  if (deleteError) throw deleteError;

  // Then create new relationships
  if (departmentIds.length > 0) {
    const relationships = departmentIds.map(deptId => ({
      subject_id: subjectId,
      department_id: deptId,
      is_primary_department: deptId === primaryDepartmentId || (primaryDepartmentId ? false : deptId === departmentIds[0])
    }));

    const { error: insertError } = await supabase
      .from("subject_departments")
      .insert(relationships);

    if (insertError) throw insertError;
  }
}

