export async function fetchAllStudentSubjectEnrollments() {
  console.log('🔍 fetchAllStudentSubjectEnrollments: Starting...');
  
  // Try to fetch from student_subject_enrollments first
  let { data, error } = await supabase
    .from("student_subject_enrollments")
    .select(`
      *,
      students(id, name, email, national_id_passport, departments(id, name)),
      subjects(id, code, name, name_en, credits, total_cost),
      semesters(id, name, name_en, study_years(id, name))
    `)
    .order("enrollment_date", { ascending: false });

  // If student_subject_enrollments doesn't exist or is empty, try student_semester_registrations
  if (error || !data || data.length === 0) {
    console.log('🔍 student_subject_enrollments not available, trying student_semester_registrations...');
    
    const { data: regData, error: regError } = await supabase
      .from("student_semester_registrations")
      .select(`
        *,
        students(id, name, email, national_id_passport, departments(id, name)),
        semesters(id, name, name_en, study_years(id, name))
      `)
      .order("registration_date", { ascending: false });

    if (regError) {
      console.error('❌ Both tables failed:', regError);
      throw regError;
    }

    // Transform student_semester_registrations to match expected format
    data = regData?.map((reg: any) => ({
      id: reg.id,
      student_id: reg.student_id,
      semester_id: reg.semester_id,
      students: reg.students,
      semesters: reg.semesters,
      enrollment_date: reg.registration_date,
      created_at: reg.created_at,
      updated_at: reg.updated_at,
      subjects: [], // No subjects in semester registrations
      subject_cost: 0,
      payment_status: reg.tuition_paid ? 'paid' : 'unpaid',
      status: reg.status
    })) || [];
  }

  console.log('✅ Found data:', data.length, 'records');
  
  // Group enrollments by student and semester
  const groupedData = new Map();
  
  data?.forEach((enrollment: any) => {
    const key = `${enrollment.student_id}-${enrollment.semester_id}`;
    
    if (!groupedData.has(key)) {
      groupedData.set(key, {
        id: key, // Use composite key as ID
        student_id: enrollment.student_id,
        semester_id: enrollment.semester_id,
        students: enrollment.students,
        semesters: enrollment.semesters,
        enrollment_date: enrollment.enrollment_date,
        created_at: enrollment.created_at,
        updated_at: enrollment.updated_at,
        subjects: [],
        total_cost: 0,
        payment_status: enrollment.payment_status,
        subject_count: 0
      });
    }
    
    const group = groupedData.get(key);
    if (enrollment.subjects) {
      group.subjects.push(enrollment.subjects);
      group.total_cost += enrollment.subject_cost || 0;
      group.subject_count += 1;
    }
    
    // Use the most recent payment status
    if (new Date(enrollment.updated_at) > new Date(group.updated_at)) {
      group.payment_status = enrollment.payment_status;
      group.updated_at = enrollment.updated_at;
    }
  });
  
  const result = Array.from(groupedData.values()).sort((a, b) => 
    new Date(b.enrollment_date).getTime() - new Date(a.enrollment_date).getTime()
  );
  
  console.log('✅ Returning grouped data:', result.length, 'groups');
  return result;
}

export async function fetchStudentSubjectEnrollmentById(enrollmentId: string) {
  console.log('🔍 fetchStudentSubjectEnrollmentById called with:', enrollmentId);
  
  // Handle different ID formats
  let data, error;
  
  // Check if it's a composite key format like "ST259172-fall-2024"
  if (enrollmentId.includes('-') && enrollmentId.split('-').length >= 2) {
    const parts = enrollmentId.split('-');
    const studentId = parts[0]; // e.g., "ST259172"
    const semesterId = parts.slice(1).join('-'); // e.g., "fall-2024"
    
    console.log('🔍 Parsed ID - studentId:', studentId, 'semesterId:', semesterId);
    console.log('🔍 Full enrollmentId:', enrollmentId);
    
    // First, try to find the student by ID or national_id_passport
    const { data: studentData, error: studentError } = await supabase
      .from("students")
      .select("id, national_id_passport")
      .or(`id.eq.${studentId},national_id_passport.eq.${studentId}`)
      .single();
    
    if (studentError || !studentData) {
      console.error('❌ Student not found:', studentError);
      throw new Error("Student not found");
    }
    
    console.log('✅ Found student:', studentData);
    
    // The semesterId could be an actual semester ID or a name
    // Try looking it up by ID first, then by name
    let semesterData = null;
    let semesterError = null;
    
    // Try by ID first
    const { data: semesterById, error: errorById } = await supabase
      .from("semesters")
      .select("id, name, name_en")
      .eq("id", semesterId)
      .maybeSingle();
    
    if (semesterById) {
      semesterData = semesterById;
    } else {
      // Try by name or name_en (case insensitive)
      const { data: semesterByName, error: errorByName } = await supabase
        .from("semesters")
        .select("id, name, name_en, code")
        .or(`name.ilike.%${semesterId}%,name_en.ilike.%${semesterId}%,code.ilike.%${semesterId}%`)
        .limit(1)
        .maybeSingle();
      
      semesterData = semesterByName;
      semesterError = errorByName;
    }
    
    if (!semesterData) {
      console.error('❌ Semester not found:', semesterError);
      console.error('❌ Searched for semester ID/name:', semesterId);
      
      // Return a more helpful error message
      throw new Error(`Semester "${semesterId}" not found in database. Please check that the semester exists.`);
    }
    
    console.log('✅ Found semester:', semesterData);
    
    // Now try to find the enrollment
    let result = await supabase
      .from("student_subject_enrollments")
      .select(`
        *,
        students(id, name, email, national_id_passport, departments(id, name)),
        subjects(id, code, name, name_en, credits, total_cost),
        semesters(id, name, name_en, start_date, end_date, study_years(id, name))
      `)
      .eq("student_id", studentData.id)
      .eq("semester_id", semesterData.id);

    data = result.data;
    error = result.error;

    // If not found, try student_semester_registrations
    if (error || !data || data.length === 0) {
      console.log('🔍 student_subject_enrollments not found, trying student_semester_registrations...');
      
      result = await supabase
        .from("student_semester_registrations")
        .select(`
          *,
          students(id, name, email, national_id_passport, departments(id, name)),
          semesters(id, name, name_en, start_date, end_date, study_years(id, name))
        `)
        .eq("student_id", studentData.id)
        .eq("semester_id", semesterData.id);

      data = result.data;
      error = result.error;

      // Transform the data to match expected format
      if (data && data.length > 0) {
        data = data.map((reg: any) => ({
          id: reg.id,
          student_id: reg.student_id,
          semester_id: reg.semester_id,
          students: reg.students,
          semesters: reg.semesters,
          enrollment_date: reg.registration_date,
          created_at: reg.created_at,
          updated_at: reg.updated_at,
          subjects: [], // No subjects in semester registrations
          subject_cost: 0,
          payment_status: reg.tuition_paid ? 'paid' : 'unpaid',
          status: reg.status
        }));
      }
    }
  } else {
    // It's a regular UUID, fetch by ID
    console.log('🔍 Using regular UUID lookup');
    let result = await supabase
      .from("student_subject_enrollments")
      .select(`
        *,
        students(id, name, email, national_id_passport, departments(id, name)),
        subjects(id, code, name, name_en, credits, total_cost),
        semesters(id, name, name_en, start_date, end_date, study_years(id, name))
      `)
      .eq("id", enrollmentId);

    data = result.data;
    error = result.error;

    // If not found, try student_semester_registrations
    if (error || !data || data.length === 0) {
      console.log('🔍 student_subject_enrollments not found, trying student_semester_registrations...');
      
      result = await supabase
        .from("student_semester_registrations")
        .select(`
          *,
          students(id, name, email, national_id_passport, departments(id, name)),
          semesters(id, name, name_en, start_date, end_date, study_years(id, name))
        `)
        .eq("id", enrollmentId);

      data = result.data;
      error = result.error;

      // Transform the data to match expected format
      if (data && data.length > 0) {
        data = data.map((reg: any) => ({
          id: reg.id,
          student_id: reg.student_id,
          semester_id: reg.semester_id,
          students: reg.students,
          semesters: reg.semesters,
          enrollment_date: reg.registration_date,
          created_at: reg.created_at,
          updated_at: reg.updated_at,
          subjects: [], // No subjects in semester registrations
          subject_cost: 0,
          payment_status: reg.tuition_paid ? 'paid' : 'unpaid',
          status: reg.status
        }));
      }
    }
  }

  if (error) {
    console.error('❌ Error fetching enrollment:', error);
    throw error;
  }
  
  if (!data || data.length === 0) {
    console.error('❌ No enrollment found for ID:', enrollmentId);
    throw new Error("Enrollment not found");
  }
  
  console.log('✅ Found enrollment data:', data.length, 'records');
  
  // Group the data similar to fetchAllStudentSubjectEnrollments
  const enrollment = data[0];
  const groupedData = {
    id: enrollmentId,
    student_id: enrollment.student_id,
    semester_id: enrollment.semester_id,
    students: enrollment.students,
    semesters: enrollment.semesters,
    enrollment_date: enrollment.enrollment_date,
    created_at: enrollment.created_at,
    updated_at: enrollment.updated_at,
    subjects: data.map(item => item.subjects).filter(Boolean),
    total_cost: data.reduce((sum, item) => sum + (item.subject_cost || 0), 0),
    payment_status: enrollment.payment_status,
    subject_count: data.filter(item => item.subjects).length
  };
  
  console.log('✅ Returning grouped data:', groupedData);
  return groupedData;
}

export async function enrollStudentInSubjects(studentId: string, subjectIds: string[], semesterId: string, departmentId: string) {
  try {
    // Check for existing enrollments first
    const { data: existingEnrollments, error: checkError } = await supabase
      .from("student_subject_enrollments")
      .select("subject_id")
      .eq("student_id", studentId)
      .eq("semester_id", semesterId)
      .in("subject_id", subjectIds);

    if (checkError) throw checkError;

    // Filter out already enrolled subjects
    const enrolledSubjectIds = existingEnrollments?.map(e => e.subject_id) || [];
    const newSubjectIds = subjectIds.filter(id => !enrolledSubjectIds.includes(id));

    if (newSubjectIds.length === 0) {
      throw new Error("جميع المقررات المختارة مسجلة مسبقاً");
    }

    if (enrolledSubjectIds.length > 0) {
      console.warn(`بعض المقررات مسجلة مسبقاً: ${enrolledSubjectIds.join(", ")}`);
    }

    // Get subject details for cost calculation
    const { data: subjects, error: subjectsError } = await supabase
      .from("subjects")
      .select("id, total_cost")
      .in("id", newSubjectIds);

    if (subjectsError) throw subjectsError;

    // Create enrollments for new subjects only
    const enrollments = newSubjectIds.map(subjectId => {
      const subject = subjects?.find(s => s.id === subjectId);
      return {
        student_id: studentId,
        subject_id: subjectId,
        semester_id: semesterId,
        department_id: departmentId,
        subject_cost: subject?.total_cost || 0,
        status: 'enrolled',
        payment_status: 'unpaid'
      };
    });

    const { data, error } = await supabase
      .from("student_subject_enrollments")
      .insert(enrollments)
      .select();

    if (error) throw error;

    // Generate invoice for new subjects only
    const totalAmount = subjects?.reduce((sum, subject) => sum + (subject.total_cost || 0), 0) || 0;
    if (totalAmount > 0) {
      await generateStudentInvoice(studentId, semesterId, departmentId, newSubjectIds, totalAmount);
    }

    return {
      data,
      enrolledSubjects: newSubjectIds,
      skippedSubjects: enrolledSubjectIds
    };
  } catch (error) {
    console.error("Error enrolling student in subjects:", error);
    throw error;
  }
}

export async function enrollStudentInSubjectsBySemesterNumber(studentId: string, subjectIds: string[], semesterNumber: number, departmentId: string) {
  try {
    // Get the semester ID based on the semester number
    // First try to find a semester that matches the semester number
    const { data: targetSemester, error: semesterError } = await supabase
      .from("semesters")
      .select("id, name, name_en")
      .eq("is_active", true)
      .order("start_date", { ascending: true })
      .limit(1)
      .single();

    if (semesterError) {
      console.error('Error finding semester:', semesterError);
      throw semesterError;
    }

    // Check for existing enrollments first
    const { data: existingEnrollments, error: checkError } = await supabase
      .from("student_subject_enrollments")
      .select("subject_id")
      .eq("student_id", studentId)
      .eq("semester_id", targetSemester.id)
      .in("subject_id", subjectIds);

    if (checkError) throw checkError;

    // Filter out already enrolled subjects
    const enrolledSubjectIds = existingEnrollments?.map(e => e.subject_id) || [];
    const newSubjectIds = subjectIds.filter(id => !enrolledSubjectIds.includes(id));

    if (newSubjectIds.length === 0) {
      throw new Error("جميع المقررات المختارة مسجلة مسبقاً");
    }

    if (enrolledSubjectIds.length > 0) {
      console.warn(`بعض المقررات مسجلة مسبقاً: ${enrolledSubjectIds.join(", ")}`);
    }

    // Get subject details for cost calculation
    const { data: subjects, error: subjectsError } = await supabase
      .from("subjects")
      .select("id, total_cost")
      .in("id", newSubjectIds);

    if (subjectsError) throw subjectsError;

    // Create enrollments for new subjects only
    const enrollments = newSubjectIds.map(subjectId => {
      const subject = subjects?.find(s => s.id === subjectId);
      return {
        student_id: studentId,
        subject_id: subjectId,
        semester_id: targetSemester.id,
        department_id: departmentId,
        subject_cost: subject?.total_cost || 0,
        status: 'enrolled',
        payment_status: 'unpaid'
      };
    });

    const { data, error } = await supabase
      .from("student_subject_enrollments")
      .insert(enrollments)
      .select();

    if (error) throw error;

    // Generate invoice for new subjects only
    const totalAmount = subjects?.reduce((sum, subject) => sum + (subject.total_cost || 0), 0) || 0;
    if (totalAmount > 0) {
      await generateStudentInvoice(studentId, targetSemester.id, departmentId, newSubjectIds, totalAmount);
    }

    return {
      data,
      enrolledSubjects: newSubjectIds,
      skippedSubjects: enrolledSubjectIds,
      semester: targetSemester
    };
  } catch (error) {
    console.error("Error enrolling student in subjects:", error);
    throw error;
  }
}

export async function generateStudentInvoice(studentId: string, semesterId: string, departmentId: string, subjectIds: string[], totalAmount: number) {
  try {
    console.log('🔍 Generating invoice for:', {
      studentId,
      semesterId,
      departmentId,
      subjectIds,
      totalAmount
    });

    // Create invoice
    const { data: invoice, error: invoiceError } = await supabase
      .from("student_invoices")
      .insert({
        student_id: studentId,
        semester_id: semesterId,
        department_id: departmentId,
        total_amount: totalAmount,
        status: 'pending'
      })
      .select()
      .single();

    if (invoiceError) {
      console.error('❌ Invoice creation error:', invoiceError);
      throw invoiceError;
    }

    console.log('✅ Invoice created successfully:', invoice);

    // Get subject details for invoice items
    const { data: subjects, error: subjectsError } = await supabase
      .from("subjects")
      .select("id, code, name, total_cost")
      .in("id", subjectIds);

    if (subjectsError) throw subjectsError;

    // Create invoice items
    const invoiceItems = subjects?.map(subject => ({
      invoice_id: invoice.id,
      subject_id: subject.id,
      description: `${subject.code} - ${subject.name}`,
      quantity: 1,
      unit_price: subject.total_cost || 0
    })) || [];

    if (invoiceItems.length > 0) {
      const { error: itemsError } = await supabase
        .from("invoice_items")
        .insert(invoiceItems);

      if (itemsError) throw itemsError;
    }

    return invoice;
  } catch (error) {
    console.error("Error generating invoice:", error);
    throw error;
  }
}

export async function fetchStudentInvoices(studentId: string, semesterId?: string) {
  let query = supabase
    .from("student_invoices")
    .select(`
      *,
      students(id, name, national_id_passport),
      semesters(id, name, name_en),
      departments(id, name, name_en),
      invoice_items(
        *,
        subjects(id, code, name, name_en)
      )
    `)
    .eq("student_id", studentId);

  if (semesterId) {
    query = query.eq("semester_id", semesterId);
  }

  const { data, error } = await query.order("invoice_date DESC");
  if (error) throw error;
  return data ?? [];
}

// Fetch all invoices with filtering options
export async function fetchAllInvoices(filters?: {
  status?: string;
  semesterId?: string;
  departmentId?: string;
  studentId?: string;
  dateFrom?: string;
  dateTo?: string;
}) {
  try {
    console.log('🔍 fetchAllInvoices called with filters:', filters);
    
    // First, try a simple query to see if we can get basic invoice data
    let basicQuery = supabase
      .from("student_invoices")
      .select("*");

    // Apply filters to basic query
    if (filters?.status) {
      basicQuery = basicQuery.eq("status", filters.status);
    }
    if (filters?.semesterId) {
      basicQuery = basicQuery.eq("semester_id", filters.semesterId);
    }
    if (filters?.departmentId) {
      basicQuery = basicQuery.eq("department_id", filters.departmentId);
    }
    if (filters?.studentId) {
      basicQuery = basicQuery.eq("student_id", filters.studentId);
    }
    if (filters?.dateFrom) {
      basicQuery = basicQuery.gte("invoice_date", filters.dateFrom);
    }
    if (filters?.dateTo) {
      basicQuery = basicQuery.lte("invoice_date", filters.dateTo);
    }

    const { data: basicData, error: basicError } = await basicQuery;
    
    if (basicError) {
      console.error('❌ Basic invoice query error:', basicError);
      if (basicError.message?.includes('relation "student_invoices" does not exist')) {
        console.warn('Invoice tables not found. Please run the migration script.');
        return [];
      }
      throw basicError;
    }

    console.log('✅ Basic invoice query successful, found:', basicData?.length || 0, 'invoices');

    if (!basicData || basicData.length === 0) {
      return [];
    }

    // Now try to get the related data for each invoice
    const enrichedData = await Promise.all(
      basicData.map(async (invoice) => {
        try {
          // Get student data
          const { data: studentData } = await supabase
            .from("students")
            .select("id, name, national_id_passport, email")
            .eq("id", invoice.student_id)
            .single();

          // Get semester data
          const { data: semesterData } = await supabase
            .from("semesters")
            .select("id, name, name_en")
            .eq("id", invoice.semester_id)
            .single();

          // Get department data
          const { data: departmentData } = await supabase
            .from("departments")
            .select("id, name, name_en")
            .eq("id", invoice.department_id)
            .single();

          // Get invoice items
          const { data: invoiceItems } = await supabase
            .from("invoice_items")
            .select(`
              *,
              subjects(id, code, name, name_en)
            `)
            .eq("invoice_id", invoice.id);

          return {
            ...invoice,
            students: studentData,
            semesters: semesterData,
            departments: departmentData,
            invoice_items: invoiceItems || []
          };
        } catch (error) {
          console.error('Error enriching invoice data for invoice:', invoice.id, error);
          return {
            ...invoice,
            students: null,
            semesters: null,
            departments: null,
            invoice_items: []
          };
        }
      })
    );

    console.log('✅ Enriched invoice data:', enrichedData.length, 'invoices');
    
    // Sort by date in JavaScript
    const sortedData = enrichedData.sort((a, b) => {
      const dateA = new Date(a.invoice_date || a.created_at || 0);
      const dateB = new Date(b.invoice_date || b.created_at || 0);
      return dateB.getTime() - dateA.getTime();
    });
    
    return sortedData;
    
  } catch (error) {
    console.error('❌ Error in fetchAllInvoices:', error);
    return [];
  }
}

// Update invoice status
export async function updateInvoiceStatus(invoiceId: string, status: string, paymentData?: {
  payment_method?: string;
  payment_date?: string;
  payment_reference?: string;
  paid_amount?: number;
}) {
  const updateData: any = { status };
  
  if (paymentData) {
    if (paymentData.payment_method) updateData.payment_method = paymentData.payment_method;
    if (paymentData.payment_date) updateData.payment_date = paymentData.payment_date;
    if (paymentData.payment_reference) updateData.payment_reference = paymentData.payment_reference;
    if (paymentData.paid_amount !== undefined) updateData.paid_amount = paymentData.paid_amount;
  }

  const { data, error } = await supabase
    .from("student_invoices")
    .update(updateData)
    .eq("id", invoiceId)
    .select()
    .single();

  if (error) throw error;
  return data;
}

// Get invoice statistics
export async function getInvoiceStatistics() {
  try {
    const { data, error } = await supabase
      .from("student_invoices")
      .select("status, total_amount, paid_amount");

    if (error) {
      console.error('Error fetching invoice statistics:', error);
      // If table doesn't exist, return empty stats
      if (error.message?.includes('relation "student_invoices" does not exist')) {
        console.warn('Invoice tables not found. Please run the migration script.');
        return {
          total: 0,
          pending: 0,
          partial: 0,
          paid: 0,
          overdue: 0,
          totalAmount: 0,
          paidAmount: 0,
          outstandingAmount: 0
        };
      }
      throw error;
    }

    const stats = {
      total: data?.length || 0,
      pending: 0,
      partial: 0,
      paid: 0,
      overdue: 0,
      totalAmount: 0,
      paidAmount: 0,
      outstandingAmount: 0
    };

    data?.forEach(invoice => {
      switch (invoice.status) {
        case 'pending':
          stats.pending++;
          break;
        case 'partial':
          stats.partial++;
          break;
        case 'paid':
          stats.paid++;
          break;
        case 'overdue':
          stats.overdue++;
          break;
      }
      
      stats.totalAmount += parseFloat(invoice.total_amount || 0);
      stats.paidAmount += parseFloat(invoice.paid_amount || 0);
    });

    stats.outstandingAmount = stats.totalAmount - stats.paidAmount;
    
    return stats;
  } catch (error) {
    console.error('Error in getInvoiceStatistics:', error);
    return {
      total: 0,
      pending: 0,
      partial: 0,
      paid: 0,
      overdue: 0,
      totalAmount: 0,
      paidAmount: 0,
      outstandingAmount: 0
    };
  }
}


export async function updateSubjectCost(subjectId: string, costPerCredit: number) {
  const { data: subject, error: subjectError } = await supabase
    .from("subjects")
    .select("credits")
    .eq("id", subjectId)
    .single();

  if (subjectError) throw subjectError;

  const totalCost = (subject.credits || 0) * costPerCredit;

  const { data, error } = await supabase
    .from("subjects")
    .update({
      cost_per_credit: costPerCredit,
      total_cost: totalCost
    })
    .eq("id", subjectId)
    .select()
    .single();

  if (error) throw error;
  return data;
}

export async function createDepartmentCurriculum(departmentId: string, semesterId: string, subjectId: string, semesterNumber: number, isRequired: boolean = true) {
  const { data, error } = await supabase
    .from("department_curriculum")
    .insert({
      department_id: departmentId,
      semester_id: semesterId,
      subject_id: subjectId,
      semester_number: semesterNumber,
      is_required: isRequired
    })
    .select()
    .single();

  if (error) throw error;
  return data;
}

export async function fetchSubjectsWithCosts(departmentId?: string) {
  let query = supabase
    .from("subjects")
    .select(`
      *,
      departments(id, name, name_en)
    `)
    .order("department_id, semester_number, name");

  if (departmentId) {
    query = query.eq("department_id", departmentId);
  }

  const { data, error } = await query;
  if (error) throw error;
  return data ?? [];
}
