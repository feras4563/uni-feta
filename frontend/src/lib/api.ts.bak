// SUBJECT-BASED STUDENT GROUP MANAGEMENT API FUNCTIONS
// ==============================================

// Test function to check if tables exist
export async function testTablesExist() {
  try {
    // Test if subject_group_enrollments table exists
    const { data, error } = await supabase
      .from("subject_group_enrollments")
      .select("id")
      .limit(1);

    if (error) {
      console.error("subject_group_enrollments table error:", error);
      return { subjectGroupEnrollments: false, error: error.message };
    }

    console.log("subject_group_enrollments table exists:", !!data);
    return { subjectGroupEnrollments: true };
  } catch (error) {
    console.error("Error testing tables:", error);
    return { subjectGroupEnrollments: false, error: error instanceof Error ? error.message : String(error) };
  }
}

export async function getStudentsInGroup(groupId: string) {
  try {
    // First check if the new table exists by testing it
    const { data: tableTest, error: tableError } = await supabase
      .from("subject_group_enrollments")
      .select("id")
      .limit(1);

    // If the new table exists and has data, use it
    if (!tableError && tableTest !== null) {
      const { data: enrollments, error: enrollmentsError } = await supabase
        .from("subject_group_enrollments")
        .select("*")
        .eq("group_id", groupId)
        .eq("status", "active");

      if (!enrollmentsError && enrollments && enrollments.length > 0) {
        // New system - fetch related data
        const studentIds = enrollments.map(enrollment => enrollment.student_id);
        const subjectIds = [...new Set(enrollments.map(enrollment => enrollment.subject_id))];
        const teacherIds = [...new Set(enrollments.map(enrollment => enrollment.teacher_id))];

        // Fetch students
        const { data: students, error: studentsError } = await supabase
          .from("students")
          .select("id, name, name_en, email, phone, national_id_passport")
          .in("id", studentIds);

        if (studentsError) throw studentsError;

        // Fetch subjects
        const { data: subjects, error: subjectsError } = await supabase
          .from("subjects")
          .select("id, name, name_en, code")
          .in("id", subjectIds);

        if (subjectsError) throw subjectsError;

        // Fetch teachers
        const { data: teachers, error: teachersError } = await supabase
          .from("teachers")
          .select("id, name, name_en")
          .in("id", teacherIds);

        if (teachersError) throw teachersError;

        // Combine the data
        const enrichedData = enrollments.map(enrollment => ({
          ...enrollment,
          students: students?.find(s => s.id === enrollment.student_id),
          subjects: subjects?.find(s => s.id === enrollment.subject_id),
          teachers: teachers?.find(t => t.id === enrollment.teacher_id)
        }));

        // Sort by student name
        return enrichedData.sort((a, b) => {
          const nameA = a.students?.name || '';
          const nameB = b.students?.name || '';
          return nameA.localeCompare(nameB);
        });
      }
    }

    // Use the old system (student_semester_registrations)
    console.log("Using old system for getStudentsInGroup");
    const { data, error } = await supabase
      .from("student_semester_registrations")
      .select("*")
      .eq("group_id", groupId)
      .eq("status", "active");

    if (error) {
      console.error("Error fetching students in group:", error);
      throw error;
    }

    if (!data || data.length === 0) {
      return [];
    }

    // Fetch students for old system
    const studentIds = data.map(reg => reg.student_id);
    const { data: students, error: studentsError } = await supabase
      .from("students")
      .select("id, name, name_en, email, phone, national_id_passport")
      .in("id", studentIds);

    if (studentsError) throw studentsError;

    // Combine the data
    const enrichedData = data.map(registration => ({
      ...registration,
      students: students?.find(s => s.id === registration.student_id)
    }));

    return enrichedData.sort((a, b) => {
      const nameA = a.students?.name || '';
      const nameB = b.students?.name || '';
      return nameA.localeCompare(nameB);
    });

  } catch (error) {
    console.error("Error in getStudentsInGroup:", error);
    throw error;
  }
}

export async function getAvailableStudentsForGroup(groupId: string, departmentId: string, semesterId: string) {
  try {
    console.log("getAvailableStudentsForGroup called with:", { groupId, departmentId, semesterId });
    
    // Get students who are not already in any group for this semester
    const { data: allStudents, error: studentsError } = await supabase
      .from("students")
      .select("*")
      .eq("department_id", departmentId)
      .eq("status", "active");

    if (studentsError) {
      console.error("Error fetching students:", studentsError);
      throw studentsError;
    }

    console.log("All students in department:", allStudents?.length || 0);

    // Get students already registered in ANY group for this semester (not just this specific group)
    const { data: registeredStudents, error: regError } = await supabase
      .from("student_semester_registrations")
      .select("student_id, group_id, student_groups(group_name)")
      .eq("semester_id", semesterId)
      .eq("status", "active");

    if (regError) {
      console.error("Error fetching registered students:", regError);
      throw regError;
    }

    console.log("Students already in ANY group for this semester:", registeredStudents?.length || 0);

    const registeredStudentIds = new Set(registeredStudents?.map(r => r.student_id) || []);
    
    // Filter out students who are already registered in ANY group for this semester
    const availableStudents = allStudents?.filter(student => 
      !registeredStudentIds.has(student.id)
    ) || [];

    console.log("Available students (not in any group for this semester):", availableStudents.length);

    // Log which students are already assigned to groups
    if (registeredStudents && registeredStudents.length > 0) {
      console.log("Students already assigned to groups:");
      registeredStudents.forEach(reg => {
        const student = allStudents?.find(s => s.id === reg.student_id);
        if (student) {
          console.log(`- ${student.name} (${student.id}) is in ${reg.student_groups?.group_name || 'Unknown Group'}`);
        }
      });
    }

    return availableStudents;
  } catch (error) {
    console.error("Error in getAvailableStudentsForGroup:", error);
    throw error;
  }
}

export async function addStudentToGroup(studentId: string, groupId: string, semesterId: string, departmentId: string, semesterNumber: number) {
  try {
    // First, check if the student is already registered in this semester
    const { data: existingRegistration, error: checkError } = await supabase
      .from("student_semester_registrations")
      .select("*, student_groups(group_name)")
      .eq("student_id", studentId)
      .eq("semester_id", semesterId)
      .eq("status", "active")
      .single();

    if (checkError && checkError.code !== 'PGRST116') { // PGRST116 = no rows returned
      throw checkError;
    }

    let result;

    if (existingRegistration) {
      // Check if student is already in a different group
      if (existingRegistration.group_id !== groupId) {
        const currentGroupName = existingRegistration.student_groups?.group_name || 'Unknown Group';
        throw new Error(`الطالب مسجل بالفعل في مجموعة أخرى (${currentGroupName}) في نفس الفصل الدراسي. لا يمكن إضافة الطالب إلى أكثر من مجموعة واحدة في نفس الفصل.`);
      }
      
      // Student is already in this group, no need to do anything
      console.log("Student is already in this group, no action needed");
      return existingRegistration;
    } else {
      // Student is not registered, create new registration
      console.log("Student not registered, creating new registration");
      const { data, error } = await supabase
        .from("student_semester_registrations")
        .insert({
          student_id: studentId,
          group_id: groupId,
          semester_id: semesterId,
          department_id: departmentId,
          semester_number: semesterNumber,
          status: 'active',
          tuition_paid: false,
          registration_date: new Date().toISOString()
        })
        .select()
        .single();

      if (error) throw error;
      result = data;
    }

    // Update group current_students count
    await updateGroupStudentCount(groupId);
    
    return result;
  } catch (error) {
    console.error("Error in addStudentToGroup:", error);
    throw error;
  }
}

export async function removeStudentFromGroup(registrationId: string, groupId: string) {
  const { error } = await supabase
    .from("student_semester_registrations")
    .delete()
    .eq("id", registrationId);

  if (error) throw error;

  // Update group current_students count
  await updateGroupStudentCount(groupId);
}

export async function updateGroupStudentCount(groupId: string) {
  // Count current students in group
  const { count, error } = await supabase
    .from("student_semester_registrations")
    .select("*", { count: "exact", head: true })
    .eq("group_id", groupId)
    .eq("status", "active");

  if (error) throw error;

  // Update group with new count
  const { error: updateError } = await supabase
    .from("student_groups")
    .update({ current_students: count || 0 })
    .eq("id", groupId);

  if (updateError) throw updateError;
}

