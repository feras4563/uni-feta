export async function fetchSubjectWithStats(subjectId: string) {
  const [subjectRes, studentsRes, departmentRes, teacherRes, titlesRes] = await Promise.all([
    supabase
      .from("subjects")
      .select("*")
      .eq("id", subjectId)
      .single(),
    supabase
      .from("students")
      .select("id, name, status")
      .eq("department_id", subjectId), // This might need adjustment based on your schema
    supabase
      .from("departments")
      .select("id, name, name_en")
      .eq("id", subjectId), // This will be updated when we get the department_id from subject
    supabase
      .from("teachers")
      .select("id, name, email")
      .eq("id", subjectId), // This will be updated when we get the teacher_id from subject
    supabase
      .from("subject_titles")
      .select("*")
      .eq("subject_id", subjectId)
      .order("order_index")
  ]);

  if (subjectRes.error) throw subjectRes.error;

  const subject = subjectRes.data;
  
  // Now fetch related data using the subject's department_id and teacher_id
  const [departmentData, teacherData] = await Promise.all([
    subject.department_id ? supabase
      .from("departments")
      .select("id, name, name_en")
      .eq("id", subject.department_id)
      .single() : Promise.resolve({ data: null, error: null }),
    subject.teacher_id ? supabase
      .from("teachers")
      .select("id, name, email")
      .eq("id", subject.teacher_id)
      .single() : Promise.resolve({ data: null, error: null })
  ]);

  return {
    subject,
    students: studentsRes.data || [],
    department: departmentData.data,
    teacher: teacherData.data,
    titles: titlesRes.data || []
  };
}

