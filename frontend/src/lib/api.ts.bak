    .eq("is_active", true)
    .order("is_primary_department", { ascending: false });

  if (error) throw error;
  return data ?? [];
}

export async function createTeacherWithDepartments(teacherData: any, departmentIds: string[], primaryDepartmentId?: string) {
  // Generate a unique teacher ID
  const generateTeacherId = () => {
    return `TCH_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
  };

  // Add the generated ID to teacher data
  const teacherDataWithId = {
    ...teacherData,
    id: generateTeacherId()
  };

  // First create the teacher
  const { data: teacher, error: teacherError } = await supabase
    .from("teachers")
    .insert(teacherDataWithId)
    .select()
    .single();

  if (teacherError) throw teacherError;

  // Then create department relationships
  if (departmentIds.length > 0) {
    const departmentRelations = departmentIds.map(deptId => ({
      teacher_id: teacher.id,
      department_id: deptId,
      is_primary_department: deptId === primaryDepartmentId,
      is_active: true
    }));

    const { error: deptError } = await supabase
      .from("teacher_departments")
      .insert(departmentRelations);

    if (deptError) throw deptError;
  }

  return teacher;
}

export async function updateTeacherDepartments(teacherId: string, departmentIds: string[], primaryDepartmentId?: string) {
  // First, delete all existing department relationships for this teacher
  const { error: deleteError } = await supabase
    .from("teacher_departments")
    .delete()
    .eq("teacher_id", teacherId);

  if (deleteError) throw deleteError;

  // Then create new relationships
  if (departmentIds.length > 0) {
    const departmentRelations = departmentIds.map(deptId => ({
      teacher_id: teacherId,
      department_id: deptId,
      is_primary_department: deptId === primaryDepartmentId,
      is_active: true
    }));

    const { error } = await supabase
      .from("teacher_departments")
      .insert(departmentRelations);

    if (error) throw error;
  }
}

export async function updateTeacher(teacherId: string, teacherData: any, departmentIds?: string[], primaryDepartmentId?: string) {
  // Update teacher data
  const { data, error } = await supabase
    .from("teachers")
    .update(teacherData)
    .eq("id", teacherId)
    .select()
    .single();

  if (error) throw error;

  // Update department relationships if provided
  if (departmentIds !== undefined) {
    await updateTeacherDepartments(teacherId, departmentIds, primaryDepartmentId);
  }

  return data;
}

