// Simple function to get basic invoice data (fallback)
export async function fetchBasicInvoices() {
  try {
    console.log('🔍 fetchBasicInvoices called');
    
    // Try without ORDER BY first to see if that's the issue
    const { data, error } = await supabase
      .from("student_invoices")
      .select("*");
    
    if (error) {
      console.error('❌ Basic invoices error:', error);
      console.error('❌ Error details:', {
        message: error.message,
        details: error.details,
        hint: error.hint,
        code: error.code
      });
      return [];
    }
    
    console.log('✅ Basic invoices found:', data?.length || 0);
    console.log('✅ Sample invoice data:', data?.[0]);
    
    // Sort in JavaScript if we have data
    if (data && data.length > 0) {
      return data.sort((a, b) => {
        const dateA = new Date(a.invoice_date || a.created_at || 0);
        const dateB = new Date(b.invoice_date || b.created_at || 0);
        return dateB.getTime() - dateA.getTime();
      });
    }
    
    return data ?? [];
  } catch (error) {
    console.error('❌ Error in fetchBasicInvoices:', error);
    return [];
  }
}

// Ultra-simple test function
export async function testSupabaseConnection() {
  try {
    console.log('🔍 Testing Supabase connection...');
    
    // Test 1: Simple count query
    const { count, error: countError } = await supabase
      .from("student_invoices")
      .select("*", { count: 'exact', head: true });
    
    console.log('🔍 Count query result:', { count, countError });
    
    // Test 2: Get one record
    const { data: oneRecord, error: oneError } = await supabase
      .from("student_invoices")
      .select("*")
      .limit(1);
    
    console.log('🔍 One record query result:', { oneRecord, oneError });
    
    // Test 3: Test auth context
    const { data: { user }, error: authError } = await supabase.auth.getUser();
    console.log('🔍 Auth context:', { user, authError });
    
    return {
      count: count || 0,
      countError,
      oneRecord: oneRecord?.[0] || null,
      oneError,
      user: user?.id || null,
      authError
    };
  } catch (error) {
    console.error('❌ Supabase connection test failed:', error);
    return {
      count: 0,
      countError: error,
      oneRecord: null,
      oneError: error,
      user: null,
      authError: error
    };
  }
}

// Test the exact query from fetchBasicInvoices
export async function testBasicInvoiceQuery() {
  try {
    console.log('🔍 Testing exact fetchBasicInvoices query...');
    
    // Test the exact query from fetchBasicInvoices
    const { data, error } = await supabase
      .from("student_invoices")
      .select("*")
      .order("invoice_date DESC");
    
    console.log('🔍 fetchBasicInvoices query result:', { 
      dataLength: data?.length || 0, 
      error,
      sampleData: data?.[0] 
    });
    
    // Test without ORDER BY
    const { data: dataNoOrder, error: errorNoOrder } = await supabase
      .from("student_invoices")
      .select("*");
    
    console.log('🔍 Query without ORDER BY result:', { 
      dataLength: dataNoOrder?.length || 0, 
      errorNoOrder 
    });
    
    // Test with limit
    const { data: dataLimit, error: errorLimit } = await supabase
      .from("student_invoices")
      .select("*")
      .limit(3);
    
    console.log('🔍 Query with limit result:', { 
      dataLength: dataLimit?.length || 0, 
      errorLimit 
    });
    
    return {
      withOrderBy: { data, error },
      withoutOrderBy: { data: dataNoOrder, error: errorNoOrder },
      withLimit: { data: dataLimit, error: errorLimit }
    };
  } catch (error) {
    console.error('❌ Basic invoice query test failed:', error);
    return {
      withOrderBy: { data: null, error },
      withoutOrderBy: { data: null, error },
      withLimit: { data: null, error }
    };
  }
}

