import { useQuery, useQueryClient } from "@tanstack/react-query";
import { useState, useMemo, useEffect } from "react";
import { useNavigate } from "react-router-dom";
import { fetchTeachers, fetchDepartments, fetchSubjects, fetchTeacherSubjects, deleteTeacherSubjectAssignment, getTeacherDepartments, createTeacherWithDepartments, updateTeacher } from "../lib/api";
import TeacherSubjectModal from "../components/teacher/TeacherSubjectModal";

export default function TeachersPage() {
  // State management
  const [searchTerm, setSearchTerm] = useState("");
  const [departmentFilter, setDepartmentFilter] = useState("");
  const [qualificationFilter, setQualificationFilter] = useState("");
  const [showModal, setShowModal] = useState(false);
  const [showProfileModal, setShowProfileModal] = useState(false);
  const [showTeacherSubjectModal, setShowTeacherSubjectModal] = useState(false);
  const [editingTeacher, setEditingTeacher] = useState<any | null>(null);
  const [selectedTeacher, setSelectedTeacher] = useState<any | null>(null);
  const [editingAssignment, setEditingAssignment] = useState<any | null>(null);
  const [currentPage, setCurrentPage] = useState(1);
  const [currentStep, setCurrentStep] = useState(1);
  const [submitting, setSubmitting] = useState(false);
  const [selectedSpecialization, setSelectedSpecialization] = useState("");
  
  const teachersPerPage = 10;
  const queryClient = useQueryClient();
  const navigate = useNavigate();

  // Form state
  const [teacherForm, setTeacherForm] = useState({
    name: '',
    name_en: '',
    department_ids: [] as string[],
    primary_department_id: '',
    email: '',
    phone: '',
    qualification: '',
    education_level: '',
    years_experience: '',
    availability: {
      sunday: { slot1: false, slot2: false, slot3: false, slot4: false, slot5: false },
      monday: { slot1: false, slot2: false, slot3: false, slot4: false, slot5: false },
      tuesday: { slot1: false, slot2: false, slot3: false, slot4: false, slot5: false },
      wednesday: { slot1: false, slot2: false, slot3: false, slot4: false, slot5: false },
      thursday: { slot1: false, slot2: false, slot3: false, slot4: false, slot5: false }
    },
    specializations: [] as string[],
    teaching_hours: '',
    hourly_rate: '',
    basic_salary: ''
  });

  // Data fetching
  const { data: teachers = [], isLoading, error } = useQuery({
    queryKey: ["teachers"],
    queryFn: () => fetchTeachers()
  });

  const { data: departments = [] } = useQuery({
    queryKey: ["departments"],
    queryFn: fetchDepartments
  });

  const { data: subjects = [] } = useQuery({
    queryKey: ["subjects"],
    queryFn: () => fetchSubjects()
  });

  // Fetch teacher subjects when a teacher is selected
  const { data: teacherSubjects = [] } = useQuery({
    queryKey: ["teacher-subjects", selectedTeacher?.id],
    queryFn: () => fetchTeacherSubjects(selectedTeacher!.id),
    enabled: !!selectedTeacher?.id
  });

  // Filter teachers
  const filteredTeachers = useMemo(() => {
    let filtered = teachers;

    // Search filter
    if (searchTerm) {
      const term = searchTerm.toLowerCase();
      filtered = filtered.filter((teacher: any) => 
        teacher.name?.toLowerCase().includes(term) ||
        teacher.name_en?.toLowerCase().includes(term) ||
        teacher.qualification?.toLowerCase().includes(term)
      );
    }

    // Department filter
    if (departmentFilter) {
      filtered = filtered.filter((teacher: any) => teacher.department_id === departmentFilter);
    }

    // Qualification filter
    if (qualificationFilter) {
      filtered = filtered.filter((teacher: any) => teacher.qualification === qualificationFilter);
    }

    return filtered;
  }, [teachers, searchTerm, departmentFilter, qualificationFilter]);

  // Calculate stats
  const stats = useMemo(() => {
    const total = teachers.length;
    const active = teachers.length; // All teachers are considered active
    const professorsCount = teachers.filter((t: any) => t.qualification === 'أستاذ').length;
    
    const teachersWithExperience = teachers.filter((t: any) => t.years_experience);
    const avgExperience = teachersWithExperience.length === 0 ? 0 : 
      Math.round(teachersWithExperience.reduce((sum: number, t: any) => sum + t.years_experience, 0) / teachersWithExperience.length);

    return { total, active, professorsCount, avgExperience };
  }, [teachers]);

  // Pagination
  const totalPages = Math.ceil(filteredTeachers.length / teachersPerPage);
  const paginatedTeachers = useMemo(() => {
    const start = (currentPage - 1) * teachersPerPage;
    const end = start + teachersPerPage;
    return filteredTeachers.slice(start, end);
  }, [filteredTeachers, currentPage]);

  const visiblePages = useMemo(() => {
    const pages = [];
    const start = Math.max(1, currentPage - 2);
    const end = Math.min(totalPages, currentPage + 2);
    
    for (let i = start; i <= end; i++) {
      pages.push(i);
    }
    return pages;
  }, [currentPage, totalPages]);

  // Multi-step form computed properties
  const availableSubjects = useMemo(() => {
    if (!teacherForm.department_ids || teacherForm.department_ids.length === 0) return [];
    return (subjects as any[]).filter((s: any) => 
      teacherForm.department_ids.includes(s.department_id)
    );
  }, [subjects, teacherForm.department_ids]);

  const workDays = [
    { key: 'sunday', name: 'الأحد' },
    { key: 'monday', name: 'الاثنين' },
    { key: 'tuesday', name: 'الثلاثاء' },
    { key: 'wednesday', name: 'الأربعاء' },
    { key: 'thursday', name: 'الخميس' }
  ];

  const timeSlots = [
    { key: 'slot1', label: '08:00 - 10:00' },
    { key: 'slot2', label: '10:00 - 12:00' },
    { key: 'slot3', label: '12:00 - 14:00' },
    { key: 'slot4', label: '14:00 - 16:00' },
    { key: 'slot5', label: '16:00 - 18:00' }
  ];

  const totalAvailableHours = useMemo(() => {
    let total = 0;
    Object.keys(teacherForm.availability).forEach(day => {
      Object.keys(teacherForm.availability[day as keyof typeof teacherForm.availability]).forEach(slot => {
        if (teacherForm.availability[day as keyof typeof teacherForm.availability][slot as keyof typeof teacherForm.availability.sunday]) {
          total += 2; // Each slot is 2 hours
        }
      });
    });
    return total;
  }, [teacherForm.availability]);

  const canProceedToNextStep = useMemo(() => {
    if (currentStep === 1) {
      return teacherForm.name && 
             teacherForm.department_ids && teacherForm.department_ids.length > 0 && 
             teacherForm.qualification &&
             teacherForm.education_level &&
             teacherForm.specializations && teacherForm.specializations.length > 0 &&
             teacherForm.years_experience &&
             teacherForm.phone;
    }
    if (currentStep === 2) {
      return teacherForm.basic_salary && 
             teacherForm.teaching_hours;
    }
    return true;
  }, [currentStep, teacherForm]);

  const isFormValid = useMemo(() => {
    return canProceedToNextStep && totalAvailableHours >= (parseInt(teacherForm.teaching_hours) || 0);
  }, [canProceedToNextStep, totalAvailableHours, teacherForm.teaching_hours]);

  // Methods
  const getDepartmentName = (departmentId: string) => {
    if (!departmentId) return 'غير محدد';
    const dept = departments.find((d: any) => d.id === departmentId);
    return dept ? dept.name : 'غير محدد';
  };

  const showAddTeacherModal = () => {
    navigate("/teachers/create");
  };

  const editTeacher = (teacher: any) => {
    // Navigate to TeacherCreate page with teacher data
    navigate(`/teachers/edit/${teacher.id}`, { 
      state: { 
        teacher: {
          ...teacher,
          availability: teacher.availability || {
            sunday: { slot1: false, slot2: false, slot3: false, slot4: false, slot5: false },
            monday: { slot1: false, slot2: false, slot3: false, slot4: false, slot5: false },
            tuesday: { slot1: false, slot2: false, slot3: false, slot4: false, slot5: false },
            wednesday: { slot1: false, slot2: false, slot3: false, slot4: false, slot5: false },
            thursday: { slot1: false, slot2: false, slot3: false, slot4: false, slot5: false }
          },
          specializations: teacher.specializations || [],
          department_ids: teacher.departments ? teacher.departments.map((d: any) => d.department_id) : [],
          primary_department_id: teacher.departments ? teacher.departments.find((d: any) => d.is_primary_department)?.department_id || '' : '',
          years_experience: teacher.years_experience || '',
          teaching_hours: teacher.teaching_hours || '',
          hourly_rate: teacher.hourly_rate || '',
          basic_salary: teacher.basic_salary || ''
        }
      }
    });
  };

  const viewTeacherProfile = (teacher: any) => {
    navigate(`/teachers/${teacher.id}`);
  };

  const closeModal = () => {
    setShowModal(false);
    setEditingTeacher(null);
    setCurrentStep(1);
    resetForm();
  };

  const closeProfileModal = () => {
    setShowProfileModal(false);
    setSelectedTeacher(null);
  };

  const resetForm = () => {
    setTeacherForm({
      name: '',
      name_en: '',
      department_ids: [],
      primary_department_id: '',
      email: '',
      phone: '',
      qualification: '',
      education_level: '',
      years_experience: '',
      availability: {
        sunday: { slot1: false, slot2: false, slot3: false, slot4: false, slot5: false },
        monday: { slot1: false, slot2: false, slot3: false, slot4: false, slot5: false },
        tuesday: { slot1: false, slot2: false, slot3: false, slot4: false, slot5: false },
        wednesday: { slot1: false, slot2: false, slot3: false, slot4: false, slot5: false },
        thursday: { slot1: false, slot2: false, slot3: false, slot4: false, slot5: false }
      },
      specializations: [],
      teaching_hours: '',
      hourly_rate: '',
      basic_salary: ''
    });
    setSelectedSpecialization('');
  };

  const addSpecialization = () => {
    if (selectedSpecialization && !teacherForm.specializations.includes(selectedSpecialization)) {
      setTeacherForm(prev => ({
        ...prev,
        specializations: [...prev.specializations, selectedSpecialization]
      }));
      setSelectedSpecialization('');
    }
  };


  const removeSpecialization = (index: number) => {
    setTeacherForm(prev => ({
      ...prev,
      specializations: prev.specializations.filter((_, i) => i !== index)
    }));
  };

  const generateTeacherId = () => {
    return `TCH_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
  };

  const submitTeacher = async (e: React.FormEvent) => {
    e.preventDefault();
    setSubmitting(true);
    
    try {
      if (editingTeacher) {
        // Update existing teacher
        const updateData = {
          name: teacherForm.name,
          name_en: teacherForm.name_en || null,
          department_id: teacherForm.department_ids.length > 0 ? teacherForm.department_ids[0] : null,
          email: teacherForm.email || null,
          phone: teacherForm.phone || null,
          qualification: teacherForm.qualification || null,
          education_level: teacherForm.education_level || null,
          years_experience: teacherForm.years_experience ? parseInt(teacherForm.years_experience) : null,
          availability: teacherForm.availability || null,
          specializations: teacherForm.specializations || null,
          teaching_hours: teacherForm.teaching_hours ? parseInt(teacherForm.teaching_hours) : null,
          hourly_rate: teacherForm.hourly_rate ? parseFloat(teacherForm.hourly_rate) : null,
          basic_salary: teacherForm.basic_salary ? parseFloat(teacherForm.basic_salary) : null
        };
        
        const { error } = await supabase
          .from('teachers')
          .update(updateData)
          .eq('id', editingTeacher.id);

        if (error) throw error;
        alert('?? مدرسون جدد? تعديل');
      } else {
        // Create new teacher
        const newTeacherData = {
          id: generateTeacherId(),
          name: teacherForm.name,
          name_en: teacherForm.name_en || null,
          department_id: teacherForm.department_ids.length > 0 ? teacherForm.department_ids[0] : null,
          email: teacherForm.email || null,
          phone: teacherForm.phone || null,
          qualification: teacherForm.qualification || null,
          education_level: teacherForm.education_level || null,
          years_experience: teacherForm.years_experience ? parseInt(teacherForm.years_experience) : null,
          availability: teacherForm.availability || null,
          specializations: teacherForm.specializations || null,
          teaching_hours: teacherForm.teaching_hours ? parseInt(teacherForm.teaching_hours) : null,
          hourly_rate: teacherForm.hourly_rate ? parseFloat(teacherForm.hourly_rate) : null,
          basic_salary: teacherForm.basic_salary ? parseFloat(teacherForm.basic_salary) : null
        };
        
        const { data: createdTeacher, error } = await supabase
          .from('teachers')
          .insert(newTeacherData)
          .select()
          .single();

        if (error) throw error;
        
        console.log('? Teacher record created:', createdTeacher);

        // Auto-create user account if email is provided
        if (teacherForm.email) {
          console.log('?? Starting auth user creation for:', teacherForm.email);
          let authCreationSuccess = false;
          const defaultPassword = 'teacher123';
          
          try {
            // Method 1: Try admin createUser (requires service role key)
            console.log('?? Attempting admin createUser...');
            const { data: adminAuthData, error: adminAuthError } = await supabase.auth.admin.createUser({
              email: teacherForm.email,
              password: defaultPassword,
              email_confirm: true, // Skip email confirmation
              user_metadata: {
                full_name: teacherForm.name,
                role: 'teacher',
                teacher_id: createdTeacher.id
              }
            });

            if (!adminAuthError && adminAuthData.user) {
              console.log('? Admin createUser successful');
              
              // Update teacher with auth_user_id
              await supabase
                .from("teachers")
                .update({ auth_user_id: adminAuthData.user.id })
                .eq("id", createdTeacher.id);

              authCreationSuccess = true;
            } else {
              console.warn('?? Admin createUser failed:', adminAuthError?.message);
              
              // Method 2: Try regular signUp as fallback
              console.log('?? Falling back to regular signUp...');
              const { data: signUpData, error: signUpError } = await supabase.auth.signUp({
                email: teacherForm.email,
                password: defaultPassword,
                options: {
                  data: {
                    full_name: teacherForm.name,
                    role: 'teacher',
                    teacher_id: createdTeacher.id
                  }
                }
              });

              if (!signUpError && signUpData.user) {
                console.log('? Regular signUp successful');
                
                // Update teacher with auth_user_id
                await supabase
                  .from("teachers")
                  .update({ auth_user_id: signUpData.user.id })
                  .eq("id", createdTeacher.id);

                authCreationSuccess = true;
              } else {
                console.error('? Both auth methods failed:', signUpError?.message);

${error.message}

✅ تم إضافة المدرس إلى قاعدة البيانات
