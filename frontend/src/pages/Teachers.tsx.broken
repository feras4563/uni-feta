const deleteTeacher = async (teacherId: string) => {
  if (!confirm('هل أنت متأكد من حذف هذا المدرس؟')) return;

  try {
    const { error } = await supabase
      .from('teachers')
      .delete()
      .eq('id', teacherId);

    if (error) throw error;
    alert('تم حذف التعيين بنجاح');
    queryClient.invalidateQueries({ queryKey: ["teachers"] });
  } catch (error: any) {
    console.error('Error deleting teacher:', error);
    alert('حدث خطأ أثناء حفظ بيانات المدرس');
  }
};

// ... (rest of the code remains the same)

const handleDeleteAssignment = async (assignmentId: string) => {
  if (!confirm('هل أنت متأكد من حذف هذا التعيين؟')) return;

  try {
    await deleteTeacherSubjectAssignment(assignmentId);
    alert('تم تحديث بيانات المدرس بنجاح');
    queryClient.invalidateQueries({ queryKey: ["teacher-subjects"] });
  } catch (error: any) {
    console.error('Error deleting assignment:', error);
    alert('حدث خطأ أثناء الحذف');
    }
  };

  const previousStep = () => {
    if (currentStep > 1) {
      setCurrentStep(currentStep - 1);
    }
  };

  const updateFormField = (field: string, value: any) => {
    setTeacherForm(prev => ({
      ...prev,
      [field]: value
    }));
  };

  const updateAvailability = (day: string, slot: string, value: boolean) => {
    setTeacherForm(prev => ({
      ...prev,
      availability: {
        ...prev.availability,
        [day]: {
          ...prev.availability[day as keyof typeof prev.availability],
          [slot]: value
        }
      }
    }));
  };

  // Effect to reset page when filters change
  useEffect(() => {
    setCurrentPage(1);
  }, [searchTerm, departmentFilter, qualificationFilter]);

  if (isLoading) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center">
        <div className="text-center">
          <div className="w-10 h-10 border-4 border-gray-300 border-t-green-500 rounded-full animate-spin mx-auto"></div>
          <p className="mt-4 text-sm text-gray-600">نشط مدرسون جدد? ?رقم الهاتف?...</p>
        </div>
      </div>
    );
  }

  if (error) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center">
        <div className="text-center">
          <div className="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-red-100">
            <svg className="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" strokeWidth="1.5" stroke="currentColor">
              <path strokeLinecap="round" strokeLinejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
          </div>
          <h3 className="mt-2 text-sm font-semibold text-gray-900">حذف ?? قائمة المدرسين</h3>
          <p className="mt-1 text-sm text-gray-500">نشط مدرسون جدد? ?رقم الهاتف?. ?رقم الهاتف حذف نشط.</p>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gray-50">
      {/* Professional Header */}
      <div className="bg-white shadow-sm border-b border-gray-200">
        <div className="px-8 py-6">
          <div className="flex justify-between items-start">
            <div className="flex items-center">
              <div className="p-3 bg-gray-100 rounded-lg ml-4">
                <svg className="h-6 w-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 14l9-5-9-5-9 5 9 5z" />
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                </svg>
              </div>
              <div>
                <h1 className="text-3xl font-bold text-gray-900">?رقم الهاتف?</h1>
                <p className="text-sm text-gray-600 mt-1">مدرسون جدد نشط إضافة مدرس جديدتعديل</p>
              </div>
            </div>
            <div className="flex gap-3">
              <button
                onClick={showAddTeacherModal}
                className="inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-800 transition-colors duration-200 shadow-sm"
                title="تعديل حذف نشط تعديل نشط"
              >
                <svg className="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                تعديل حذف نشط تعديل
              </button>
              <button
                onClick={exportTeachers}
                className="inline-flex items-center px-4 py-2 bg-gray-600 text-white text-sm font-medium rounded-lg hover:bg-gray-700 transition-colors duration-200 shadow-sm"
                title="قائمة المدرسين"
              >
                <svg className="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                تعديل
              </button>
            </div>
          </div>
        </div>
      </div>

      <div className="p-8">

        {/* Professional Statistics Cards */}
        <div className="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
          <div className="bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow duration-200">
            <div className="flex items-center justify-between">
              <div>
                <div className="text-3xl font-bold text-gray-900">{stats.total}</div>
                <div className="text-sm font-medium text-gray-600 mt-1">تعديل? ?رقم الهاتف?</div>
              </div>
              <div className="p-3 bg-gray-100 rounded-lg">
                <svg className="h-6 w-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
                </svg>
              </div>
            </div>
          </div>
          
          <div className="bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow duration-200">
            <div className="flex items-center justify-between">
              <div>
                <div className="text-3xl font-bold text-gray-900">{stats.active}</div>
                <div className="text-sm font-medium text-gray-600 mt-1">تعديل نشط إضافة مدرس جديدحذف</div>
              </div>
              <div className="p-3 bg-green-100 rounded-lg">
                <svg className="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
            </div>
          </div>
          
          <div className="bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow duration-200">
            <div className="flex items-center justify-between">
              <div>
                <div className="text-3xl font-bold text-gray-900">{stats.professorsCount}</div>
                <div className="text-sm font-medium text-gray-600 mt-1">تعديل?</div>
              </div>
              <div className="p-3 bg-purple-100 rounded-lg">
                <svg className="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 14l9-5-9-5-9 5 9 5z" />
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                </svg>
              </div>
            </div>
          </div>
          
          <div className="bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow duration-200">
            <div className="flex items-center justify-between">
              <div>
                <div className="text-3xl font-bold text-gray-900">{stats.avgExperience}</div>
                <div className="text-sm font-medium text-gray-600 mt-1">مدرسون جدد? (تعديل)</div>
              </div>
              <div className="p-3 bg-blue-100 rounded-lg">
                <svg className="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
            </div>
          </div>
        </div>

        {/* Professional Search and Filters */}
        <div className="bg-white rounded-lg shadow-sm border border-gray-200 mb-8">
          <div className="px-6 py-4 border-b border-gray-200">
            <h3 className="text-lg font-semibold text-gray-900 flex items-center">
              <svg className="w-5 h-5 mr-2 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
              </svg>
              قائمة المدرسين
            </h3>
          </div>
          <div className="p-6">
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              <div className="relative">
                <input
                  type="text"
                  value={searchTerm}
                  onChange={(e) => {
                    setSearchTerm(e.target.value);
                    searchTeachers();
                  }}
                  placeholder="تعديل ?? ?رقم الهاتف?..."
                  className="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-gray-500 transition-colors duration-200"
                />
                <svg className="absolute left-3 top-3.5 h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </div>
              
              <select
                value={departmentFilter}
                onChange={(e) => {
                  setDepartmentFilter(e.target.value);
                  filterTeachers();
                }}
                className="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-gray-500 transition-colors duration-200 bg-white"
              >
                <option value="">?رقم الهاتف</option>
                {departments.map((dept: any) => (
                  <option key={dept.id} value={dept.id}>
                    {dept.name}
                  </option>
                ))}
              </select>
              
              <select
                value={qualificationFilter}
                onChange={(e) => {
                  setQualificationFilter(e.target.value);
                  filterTeachers();
                }}
                className="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-gray-500 transition-colors duration-200 bg-white"
              >
                <option value="">نشط تعديل</option>
                <option value="تعديل">تعديل</option>
                <option value="مدرسون جدد">مدرسون جدد</option>
                <option value="مدرسون جدد">مدرسون جدد</option>
                <option value="تعديل">تعديل</option>
              </select>
            </div>
            
            {/* Results Summary */}
            <div className="mt-4 pt-4 border-t border-gray-200">
              <p className="text-sm text-gray-600">
                حذف {paginatedTeachers.length} ?? حذف {filteredTeachers.length} حذف نشط تعديل
                {filteredTeachers.length !== teachers.length && (
                  <span className="text-gray-500"> (?? تعديل {teachers.length - filteredTeachers.length} تعديل)</span>
                )}
              </p>
            </div>
          </div>
        </div>

        {/* Professional Teachers Table */}
        <div className="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
          <div className="px-6 py-4 border-b border-gray-200 bg-gray-50">
            <h3 className="text-lg font-semibold text-gray-900 flex items-center">
              <svg className="w-5 h-5 mr-2 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
              تعديل ?رقم الهاتف?
            </h3>
          </div>
          
          <div className="overflow-x-auto">
            <table className="w-full">
              <thead className="bg-gray-50 border-b border-gray-200">
                <tr>
                  <th className="px-6 py-4 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">تعديل</th>
                  <th className="px-6 py-4 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">?مدرسون جدد??</th>
                  <th className="px-6 py-4 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">تعديل?</th>
                  <th className="px-6 py-4 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">تعديل?</th>
                  <th className="px-6 py-4 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">?قائمة المدرسين??</th>
                  <th className="px-6 py-4 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">تعديلنشط</th>
                </tr>
              </thead>
              <tbody className="bg-white divide-y divide-gray-200">
                {paginatedTeachers.map((teacher: any, index: number) => (
                  <tr key={teacher.id} className={`hover:bg-gray-50 transition-colors duration-150 ${index % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}`}>
                    <td className="px-6 py-4 whitespace-nowrap">
                      <div className="flex items-center">
                        <div className="p-2 bg-gray-100 rounded-lg ml-3">
                          <svg className="h-4 w-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                          </svg>
                        </div>
                        <div>
                          <div className="text-sm font-semibold text-gray-900">{teacher.name}</div>
                          {teacher.name_en && (
                            <div className="text-xs text-gray-500">{teacher.name_en}</div>
                          )}
                        </div>
                      </div>
                    </td>
                    <td className="px-6 py-4 whitespace-nowrap">
                      <div className="flex items-center">
                        <div className="p-1 bg-purple-100 rounded ml-2">
                          <svg className="h-3 w-3 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 14l9-5-9-5-9 5 9 5z" />
                          </svg>
                        </div>
                        <span className="text-sm text-gray-900">{teacher.qualification || 'حذف نشط'}</span>
                      </div>
                    </td>
                    <td className="px-6 py-4 whitespace-nowrap">
                      <div className="text-sm text-gray-900">
                        {teacher.departments && teacher.departments.length > 0 ? (
                          <div className="flex flex-wrap gap-1">
                            {teacher.departments.slice(0, 2).map((dept: any, index: number) => (
                              <span key={index} className={`inline-flex items-center px-2 py-1 text-xs rounded-full ${
                                dept.is_primary_department 
                                  ? 'bg-blue-100 text-blue-800' 
                                  : 'bg-gray-100 text-gray-800'
                              }`}>
                                {dept.department_name}
                                {dept.is_primary_department && (
                                  <span className="mr-1 px-1 bg-blue-200 text-blue-900 text-xs rounded-full">
                                    تعديل
                                  </span>
                                )}
                              </span>
                            ))}
                            {teacher.departments.length > 2 && (
                              <span className="text-xs text-gray-500">
                                +{teacher.departments.length - 2} نشط
                              </span>
                            )}
                          </div>
                        ) : (
                          <span className="text-gray-500">حذف نشط</span>
                        )}
                      </div>
                    </td>
                    <td className="px-6 py-4 whitespace-nowrap">
                      <div className="flex items-center">
                        <div className="p-1 bg-blue-100 rounded ml-2">
                          <svg className="h-3 w-3 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                          </svg>
                        </div>
                        <span className="text-sm text-gray-900">
                          {teacher.years_experience ? `${teacher.years_experience} تعديل` : 'حذف نشط'}
                        </span>
                      </div>
                    </td>
                    <td className="px-6 py-4 whitespace-nowrap">
                      <div className="text-sm text-gray-900 font-mono">{teacher.email || 'حذف نشط'}</div>
                    </td>
                    <td className="px-6 py-4 whitespace-nowrap">
                      <div className="flex items-center space-x-1 space-x-reverse">
                        <button
                          onClick={() => viewTeacherProfile(teacher)}
                          className="p-2 text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-100 transition-colors duration-200"
                          title="حذف مدرسون جدد?"
                        >
                          <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                          </svg>
                        </button>
                        <button
                          onClick={() => editTeacher(teacher)}
                          className="p-2 text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-100 transition-colors duration-200"
                          title="تعديل"
                        >
                          <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                          </svg>
                        </button>
                        <button
                          onClick={() => deleteTeacher(teacher.id)}
                          className="p-2 text-red-600 hover:text-red-900 rounded-lg hover:bg-red-50 transition-colors duration-200"
                          title="حذف"
                        >
                          <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                          </svg>
                        </button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        {/* Professional Pagination */}
        {totalPages > 1 && (
          <div className="mt-8 bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <div className="flex justify-between items-center">
              <div className="text-sm text-gray-600">
                نشط {currentPage} ?? {totalPages} ({filteredTeachers.length} حذف نشط تعديل)
              </div>
              <div className="flex items-center space-x-2 space-x-reverse">
                <button
                  onClick={() => changePage(currentPage - 1)}
                  disabled={currentPage === 1}
                  className="px-4 py-2 text-sm font-medium text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors duration-200"
                >
                  تعديل?
                </button>
                
                {visiblePages.map((page) => (
                  <button
                    key={page}
                    onClick={() => changePage(page)}
                    className={`px-4 py-2 text-sm font-medium rounded-lg transition-colors duration-200 ${
                      page === currentPage
                        ? 'bg-gray-900 text-white'
                        : 'text-gray-700 bg-white border border-gray-300 hover:bg-gray-50'
                    }`}
                  >
                    {page}
                  </button>
                ))}
                
                <button
                  onClick={() => changePage(currentPage + 1)}
                  disabled={currentPage === totalPages}
                  className="px-4 py-2 text-sm font-medium text-gray-600 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors duration-200"
                >
                  تعديل?
                </button>
              </div>
            </div>
          </div>
        )}
      </div>

      {/* Add/Edit Teacher Modal */}
      {showModal && (
        <div className="fixed inset-0 z-50 overflow-y-auto">
          <div className="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div className="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" onClick={closeModal}></div>

            <div className="inline-block align-bottom bg-white rounded-lg text-right overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-4xl sm:w-full">
              <div className="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                <div className="flex items-center justify-between mb-6">
                  <button
                    onClick={closeModal}
                    className="text-gray-400 hover:text-gray-600 text-2xl"
                  >
                    �
                  </button>
                  <h2 className="text-xl font-semibold text-gray-900">
                    {editingTeacher ? 'تعديل حذف ?رقم الهاتف?' : 'تعديل حذف نشط تعديل نشط'}
                  </h2>
                </div>

                {/* Step Indicators */}
                <div className="flex justify-center mb-8">
                  <div className="flex items-center space-x-8 space-x-reverse">
                    {[1, 2, 3].map((step) => (
                      <div key={step} className="flex items-center">
                        <div className={`flex items-center justify-center w-8 h-8 rounded-full border-2 ${
                          currentStep >= step ? 'bg-green-600 border-green-600 text-white' : 'border-gray-300 text-gray-500'
                        } ${currentStep > step ? 'bg-green-600' : ''}`}>
                          {currentStep > step ? (
                            <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                              <path fillRule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clipRule="evenodd" />
                            </svg>
                          ) : (
                            step
                          )}
                        </div>
                        <div className={`mr-2 text-sm font-medium ${currentStep >= step ? 'text-green-600' : 'text-gray-500'}`}>
                          {step === 1 && '??إضافة مدرس جديدحذف'}
                          {step === 2 && '?قائمة المدرسين'}
                          {step === 3 && '?قائمة المدرسين'}
                        </div>
                        {step < 3 && <div className="w-16 h-0.5 bg-gray-300 mx-4" />}
                      </div>
                    ))}
                  </div>
                </div>

                <form onSubmit={submitTeacher}>
                  {/* Step 1: Personal Information */}
                  {currentStep === 1 && (
                    <div className="space-y-6">
                      <h3 className="text-lg font-medium text-green-600 mb-6 pb-4 border-b-2 border-gray-200">??إضافة مدرس جديدحذف</h3>
                      
                      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                          <label className="block text-sm font-medium text-gray-700 mb-2">
                            مدرسون جدد? *
                          </label>
                          <input
                            type="text"
                            value={teacherForm.name}
                            onChange={(e) => updateFormField('name', e.target.value)}
                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                            placeholder="مدرسون جدد?"
                            required
                          />
                        </div>
                        
                        <div>
                          <label className="block text-sm font-medium text-gray-700 mb-2">
                            قائمة المدرسينحذف
                          </label>
                          <input
                            type="text"
                            value={teacherForm.name_en}
                            onChange={(e) => updateFormField('name_en', e.target.value)}
                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                            placeholder="Full Name in English"
                          />
                        </div>

                        <div>
                          <label className="block text-sm font-medium text-gray-700 mb-2">
                            تعديل?? *
                          </label>
                          <div className="space-y-2 max-h-48 overflow-y-auto border border-gray-200 rounded-lg p-3">
                            {departments.map((dept: any) => (
                              <label key={dept.id} className="flex items-center space-x-3 cursor-pointer hover:bg-gray-50 p-2 rounded">
                                <input
                                  type="checkbox"
                                  checked={teacherForm.department_ids && teacherForm.department_ids.includes(dept.id)}
                                  onChange={(e) => {
                                    if (e.target.checked) {
                                      setTeacherForm(prev => ({
                                        ...prev,
                                        department_ids: [...(prev.department_ids || []), dept.id]
                                      }));
                                    } else {
                                      setTeacherForm(prev => ({
                                        ...prev,
                                        department_ids: (prev.department_ids || []).filter((id: string) => id !== dept.id),
                                        primary_department_id: prev.primary_department_id === dept.id ? '' : prev.primary_department_id
                                      }));
                                    }
                                  }}
                                  className="h-4 w-4 text-green-600 focus:ring-green-500 border-gray-300 rounded"
                                />
                                <span className="text-sm text-gray-900">{dept.name}</span>
                                {teacherForm.department_ids && teacherForm.department_ids.includes(dept.id) && (
                                  <span className="text-xs text-green-600 font-medium">? نشط</span>
                                )}
                              </label>
                            ))}
                          </div>
                          {teacherForm.department_ids && teacherForm.department_ids.length > 1 && (
                            <div className="mt-3">
                              <label className="block text-sm font-medium text-gray-700 mb-1">
                                مدرسون جدد??
                              </label>
                              <select
                                value={teacherForm.primary_department_id}
                                onChange={(e) => updateFormField('primary_department_id', e.target.value)}
                                className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                              >
                                <option value="">نشط مدرسون جدد??</option>
                                {teacherForm.department_ids.map((deptId) => {
                                  const dept = departments.find((d: any) => d.id === deptId);
                                  return (
                                    <option key={deptId} value={deptId}>
                                      {dept?.name}
                                    </option>
                                  );
                                })}
                              </select>
                            </div>
                          )}
                          <small className="text-gray-500">نشط ?تصفية حسب القسم</small>
                        </div>

                        <div>
                          <label className="block text-sm font-medium text-gray-700 mb-2">
                            ?مدرسون جدد? *
                          </label>
                          <select
                            value={teacherForm.education_level}
                            onChange={(e) => updateFormField('education_level', e.target.value)}
                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                            required
                          >
                            <option value="">نشط ?مدرسون جدد?</option>
                            <option value="تعديل??">تعديل?? (PhD)</option>
                            <option value="تعديل??">تعديل?? (Masters)</option>
                            <option value="تعديلنشط">تعديلنشط (Bachelor)</option>
                            <option value="تعديل نشط">تعديل نشط</option>
                            <option value="تعديل">تعديل</option>
                          </select>
                        </div>

                        <div>
                          <label className="block text-sm font-medium text-gray-700 mb-2">
                            ?مدرسون جدد?? *
                          </label>
                          <select
                            value={teacherForm.qualification}
                            onChange={(e) => updateFormField('qualification', e.target.value)}
                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                            required
                          >
                            <option value="">?رقم الهاتف</option>
                            <option value="تعديل">تعديل</option>
                            <option value="مدرسون جدد">مدرسون جدد</option>
                            <option value="مدرسون جدد">مدرسون جدد</option>
                            <option value="تعديل">تعديل</option>
                          </select>
                        </div>

                        <div>
                          <label className="block text-sm font-medium text-gray-700 mb-2">
                            مدرسون جدد? *
                          </label>
                          <input
                            type="number"
                            value={teacherForm.years_experience || ''}
                            onChange={(e) => updateFormField('years_experience', e.target.value)}
                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                            min="0"
                            max="50"
                            placeholder="حذف مدرسون جدد?"
                            required
                          />
                        </div>

                        <div>
                          <label className="block text-sm font-medium text-gray-700 mb-2">
                            ?قائمة المدرسين??
                          </label>
                          <input
                            type="email"
                            value={teacherForm.email}
                            onChange={(e) => updateFormField('email', e.target.value)}
                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                            placeholder="?قائمة المدرسين??"
                          />
                        </div>

                        <div>
                          <label className="block text-sm font-medium text-gray-700 mb-2">
                            رقم الهاتف *
                          </label>
                          <input
                            type="tel"
                            value={teacherForm.phone}
                            onChange={(e) => updateFormField('phone', e.target.value)}
                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                            placeholder="رقم الهاتف"
                            required
                          />
                        </div>
                      </div>

                      {/* Specializations */}
                      <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">
                          ?إضافة مدرس جديدحذف *
                        </label>
                        {teacherForm.specializations.length > 0 && (
                          <div className="flex flex-wrap gap-2 mb-4">
                            {teacherForm.specializations.map((spec, index) => (
                              <div key={index} className="inline-flex items-center bg-green-600 text-white px-3 py-1 rounded-full text-sm">
                                {spec}
                                <button
                                  type="button"
                                  onClick={() => removeSpecialization(index)}
                                  className="ml-2 text-white hover:bg-white hover:text-green-600 rounded-full w-5 h-5 flex items-center justify-center"
                                >
                                  �
                                </button>
                              </div>
                            ))}
                          </div>
                        )}
                        <div className="flex gap-2">
                          <select
                            value={selectedSpecialization}
                            onChange={(e) => setSelectedSpecialization(e.target.value)}
                            className="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                          >
                            <option value="">نشط نشط ?رقم الهاتف?</option>
                            {availableSubjects.map((subject: any) => (
                              <option key={subject.id} value={subject.name}>
                                {subject.name} ({subject.code})
                              </option>
                            ))}
                          </select>
                          <button
                            type="button"
                            onClick={addSpecialization}
                            className="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700"
                          >
                            تعديل
                          </button>
                        </div>
                        <small className="text-gray-500">?رقم الهاتف حذف ?مدرسون جدد</small>
                      </div>
                    </div>
                  )}

                  {/* Step 2: Salary and Hours */}
                  {currentStep === 2 && (
                    <div className="space-y-6">
                      <h3 className="text-lg font-medium text-green-600 mb-6 pb-4 border-b-2 border-gray-200">إضافة مدرس جديد?? تعديلحذف</h3>
                      
                      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                          <label className="block text-sm font-medium text-gray-700 mb-2">
                            ?مدرسون جدد?? *
                          </label>
                          <input
                            type="number"
                            value={teacherForm.basic_salary || ''}
                            onChange={(e) => updateFormField('basic_salary', e.target.value)}
                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                            min="0"
                            step="0.01"
                            placeholder="تعديل? إضافة مدرس جديد?رقم الهاتف"
                            required
                          />
                        </div>

                        <div>
                          <label className="block text-sm font-medium text-gray-700 mb-2">
                            نشط ?قائمة المدرسين
                          </label>
                          <input
                            type="number"
                            value={teacherForm.hourly_rate || ''}
                            onChange={(e) => updateFormField('hourly_rate', e.target.value)}
                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                            min="0"
                            step="0.01"
                            placeholder="نشط ?قائمة المدرسين"
                          />
                        </div>

                        <div>
                          <label className="block text-sm font-medium text-gray-700 mb-2">
                            تعديل إضافة مدرس جديدقائمة المدرسين *
                          </label>
                          <input
                            type="number"
                            value={teacherForm.teaching_hours || ''}
                            onChange={(e) => updateFormField('teaching_hours', e.target.value)}
                            className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent"
                            min="1"
                            max="40"
                            placeholder="حذف إضافة مدرس جديدتعديل"
                            required
                          />
                          <small className="text-gray-500">?رقم الهاتف 40 ?رقم الهاتف</small>
                        </div>


                      </div>
                    </div>
                  )}

                  {/* Step 3: Weekly Availability */}
                  {currentStep === 3 && (
                    <div className="space-y-6">
                      <h3 className="text-lg font-medium text-green-600 mb-6 pb-4 border-b-2 border-gray-200">تعديل? ?إضافة مدرس جديدحذف</h3>
                      
                      <div className="border border-gray-300 rounded-lg overflow-hidden">
                        <div className="grid grid-cols-6 bg-gray-50 border-b">
                          <div className="px-4 py-3 font-medium text-gray-700 border-r">تعديل</div>
                          {workDays.map((day) => (
                            <div key={day.key} className="px-4 py-3 font-medium text-gray-700 text-center border-r">
                              {day.name}
                            </div>
                          ))}
                        </div>
                        
                        {timeSlots.map((slot) => (
                          <div key={slot.key} className="grid grid-cols-6 border-b last:border-b-0">
                            <div className="px-4 py-4 bg-gray-50 border-r font-medium text-sm text-gray-700">
                              {slot.label}
                            </div>
                            {workDays.map((day) => (
                              <div key={day.key} className="px-4 py-4 border-r flex justify-center">
                                <input
                                  type="checkbox"
                                  id={`${day.key}-${slot.key}`}
                                  checked={teacherForm.availability[day.key as keyof typeof teacherForm.availability][slot.key as keyof typeof teacherForm.availability.sunday]}
                                  onChange={(e) => updateAvailability(day.key, slot.key, e.target.checked)}
                                  className="w-6 h-6 text-green-600 rounded focus:ring-green-500"
                                />
                              </div>
                            ))}
                          </div>
                        ))}
                      </div>
                      
                      <div className="bg-gray-50 p-4 rounded-lg">
                        <h4 className="font-medium text-green-600 mb-2">?رقم الهاتف</h4>
                        <p>تعديل? إضافة مدرس جديدحذف: <strong>{totalAvailableHours}</strong> ?رقم الهاتف</p>
                        <p className="text-sm text-gray-600">نشط تعديل إضافة مدرس جديدرقم الهاتف? (?? نشط ?رقم الهاتف)</p>
                      </div>
                    </div>
                  )}

                  {/* Form Navigation */}
                  <div className="flex justify-between items-center pt-6 border-t border-gray-200 mt-8">
                    <div className="flex gap-3">
                      <button
                        type="button"
                        onClick={closeModal}
                        className="px-4 py-2 text-gray-700 bg-gray-200 rounded-lg hover:bg-gray-300"
                      >
                        تعديل
                      </button>
                      {currentStep > 1 && (
                        <button
                          type="button"
                          onClick={previousStep}
                          className="px-4 py-2 text-blue-700 bg-blue-100 rounded-lg hover:bg-blue-200"
                        >
                          تعديل?
                        </button>
                      )}
                    </div>
                    
                    <div>
                      {currentStep < 3 ? (
                        <button
                          type="button"
                          onClick={nextStep}
                          disabled={!canProceedToNextStep}
                          className="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed"
                        >
                          تعديل?
                        </button>
                      ) : (
                        <button
                          type="submit"
                          disabled={submitting || !isFormValid}
                          className="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 disabled:opacity-50 disabled:cursor-not-allowed"
                        >
                          {submitting ? 'نشط تعديل...' : (editingTeacher ? 'تعديل' : 'تعديل')}
                        </button>
                      )}
                    </div>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Teacher Profile Modal */}
      {showProfileModal && selectedTeacher && (
        <div className="fixed inset-0 z-50 overflow-y-auto">
          <div className="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div className="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" onClick={closeProfileModal}></div>

            <div className="inline-block align-bottom bg-white rounded-lg text-right overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-2xl sm:w-full">
              <div className="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                <div className="flex items-center justify-between mb-6">
                  <button
                    onClick={closeProfileModal}
                    className="text-gray-400 hover:text-gray-600 text-2xl"
                  >
                    �
                  </button>
                  <h2 className="text-xl font-semibold text-gray-900">
                    مدرسون جدد? نشط ?رقم الهاتف?
                  </h2>
                </div>

                <div className="space-y-6">
                  <div className="pb-4 border-b border-gray-200">
                    <h3 className="text-lg font-semibold text-gray-900">{selectedTeacher.name}</h3>
                    <p><strong>?مدرسون جدد??:</strong> {selectedTeacher.qualification || 'حذف نشط'}</p>
                    <p><strong>تعديل??:</strong> 
                      {selectedTeacher.departments && selectedTeacher.departments.length > 0 ? (
                        <div className="mt-1">
                          <div className="flex flex-wrap gap-1">
                            {selectedTeacher.departments.map((dept: any, index: number) => (
                              <span key={index} className={`inline-flex items-center px-2 py-1 text-xs rounded-full ${
                                dept.is_primary_department 
                                  ? 'bg-blue-100 text-blue-800' 
                                  : 'bg-gray-100 text-gray-800'
                              }`}>
                                {dept.department_name}
                                {dept.is_primary_department && (
                                  <span className="mr-1 px-1 bg-blue-200 text-blue-900 text-xs rounded-full">
                                    تعديل
                                  </span>
                                )}
                              </span>
                            ))}
                          </div>
                        </div>
                      ) : (
                        <span className="text-gray-500">حذف نشط</span>
                      )}
                    </p>
                    <p><strong>مدرسون جدد?:</strong> {selectedTeacher.years_experience ? `${selectedTeacher.years_experience} تعديل` : 'حذف نشط'}</p>
                  </div>
                  
                  <div>
                    <h4 className="font-medium text-gray-900 mb-3">إضافة مدرس جديدحذف</h4>
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                      <div>
                        <span className="font-medium">?قائمة المدرسين??:</span>
                        <span className="mr-2">{selectedTeacher.email || 'حذف نشط'}</span>
                      </div>
                      <div>
                        <span className="font-medium">رقم الهاتف:</span>
                        <span className="mr-2">{selectedTeacher.phone || 'حذف نشط'}</span>
                      </div>
                    </div>
                  </div>
                  
                  <div>
                    <h4 className="font-medium text-gray-900 mb-3">??إضافة مدرس جديدحذف</h4>
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                      <div>
                        <span className="font-medium">?إضافة مدرس جديدحذف:</span>
                        <div className="mt-1">
                          {selectedTeacher.specializations && selectedTeacher.specializations.length > 0 ? (
                            <div className="flex flex-wrap gap-1">
                              {selectedTeacher.specializations.map((spec: string, index: number) => (
                                <span key={index} className="inline-flex items-center px-2 py-1 bg-blue-100 text-blue-800 text-xs rounded-full">
                                  {spec}
                                </span>
                              ))}
                            </div>
                          ) : (
                            <span className="text-gray-500">حذف نشط</span>
                          )}
                        </div>
                      </div>
                      <div>
                        <span className="font-medium">مدرسون جدد??:</span>
                        <span className="mr-2">{selectedTeacher.teaching_hours ? `${selectedTeacher.teaching_hours} نشط/تعديل` : 'حذف نشط'}</span>
                      </div>
                      <div>
                        <span className="font-medium">?رقم الهاتف:</span>
                        <span className="mr-2">{selectedTeacher.hourly_rate ? `${selectedTeacher.hourly_rate} تعديل` : 'حذف نشط'}</span>
                      </div>
                    </div>
                  </div>

                  {/* Teacher Subjects Section */}
                  <div>
                    <div className="flex items-center justify-between mb-3">
                      <h4 className="font-medium text-gray-900">?إضافة مدرس جديدحذف</h4>
                      <button
                        onClick={() => handleAddSubject(selectedTeacher)}
                        className="inline-flex items-center px-3 py-1 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors duration-200"
                      >
                        <svg className="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                        </svg>
                        تعديل نشط
                      </button>
                    </div>
                    
                    {teacherSubjects.length > 0 ? (
                      <div className="space-y-2">
                        {teacherSubjects.map((assignment: any) => (
                          <div key={assignment.id} className="bg-gray-50 rounded-lg p-3 border border-gray-200">
                            <div className="flex items-center justify-between">
                              <div className="flex-1">
                                <div className="flex items-center">
                                  <h5 className="font-medium text-gray-900 text-sm">
                                    {assignment.subject?.name} ({assignment.subject?.code})
                                  </h5>
                                  {assignment.is_primary_teacher && (
                                    <span className="mr-2 px-2 py-1 bg-blue-100 text-blue-800 text-xs rounded-full">
                                      تعديل
                                    </span>
                                  )}
                                </div>
                                <div className="text-xs text-gray-600 mt-1">
                                  {assignment.department?.name} � {assignment.academic_year} � {assignment.semester === 'fall' ? 'مدرسون جدد' : assignment.semester === 'spring' ? 'مدرسون جدد?' : 'مدرسون جدد?'}
                                </div>
                                <div className="flex items-center mt-1 space-x-4 text-xs text-gray-500">
                                  {assignment.can_edit_grades && <span>مدرسون جدد??</span>}
                                  {assignment.can_take_attendance && <span>رقم الهاتف</span>}
                                </div>
                              </div>
                              <div className="flex items-center space-x-2">
                                <button
                                  onClick={() => handleEditAssignment(assignment)}
                                  className="p-1 text-gray-400 hover:text-blue-600 transition-colors duration-200"
                                  title="تعديل"
                                >
                                  <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                  </svg>
                                </button>
                                <button
                                  onClick={() => handleDeleteAssignment(assignment.id)}
                                  className="p-1 text-gray-400 hover:text-red-600 transition-colors duration-200"
                                  title="حذف"
                                >
                                  <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                  </svg>
                                </button>
                              </div>
                            </div>
                          </div>
                        ))}
                      </div>
                    ) : (
                      <div className="text-center py-4 text-gray-500">
                        <p className="text-sm">?? نشط ?مدرسون جدد ?رقم الهاتف</p>
                        <button
                          onClick={() => handleAddSubject(selectedTeacher)}
                          className="mt-2 text-blue-600 hover:text-blue-700 text-sm font-medium"
                        >
                          تعديل حذف نشط
                        </button>
                      </div>
                    )}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Teacher Subject Modal */}
      <TeacherSubjectModal
        isOpen={showTeacherSubjectModal}
        onClose={handleCloseTeacherSubjectModal}
        teacherId={selectedTeacher?.id}
        editingAssignment={editingAssignment}
        mode="teacher"
      />
    </div>
  );
}
